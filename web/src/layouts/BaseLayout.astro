---
/**
 * Base HTML layout for all GCD domain sites.
 * Renders the navigation, domain header, and page content.
 */
export interface Props {
  title: string;
  description?: string;
  primaryColor?: string;
  accentColor?: string;
}

const { title, description = '', primaryColor = '#0f172a', accentColor = '#f59e0b' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} — GCD Kernel</title>
    <style define:vars={{ primaryColor, accentColor }}>
      :root {
        --color-primary: var(--primaryColor);
        --color-accent: var(--accentColor);
      }
    </style>
  </head>
  <body class="bg-kernel-950 text-kernel-100 min-h-screen">
    <!-- Navigation -->
    <nav class="border-b border-kernel-800 px-6 py-3">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href={base} class="text-lg font-bold tracking-tight">
          GCD<span class="text-kernel-400">·</span>Kernel
        </a>
        <div class="flex items-center gap-1 text-sm text-kernel-400">
          <!-- Primary nav -->
          <a href={base} class="hover:text-kernel-100 transition px-2 py-1">Domains</a>
          <span class="text-kernel-700">|</span>
          <!-- Tools -->
          <a href={`${base}calculator/`} class="hover:text-kernel-100 transition px-2 py-1">Calculator</a>
          <a href={`${base}regime/`} class="hover:text-kernel-100 transition px-2 py-1">Regime</a>
          <a href={`${base}diagnostics/`} class="hover:text-kernel-100 transition px-2 py-1">τ_R*</a>
          <a href={`${base}precision/`} class="hover:text-kernel-100 transition px-2 py-1">Precision</a>
          <span class="text-kernel-700">|</span>
          <!-- Reference -->
          <a href={`${base}formulas/`} class="hover:text-kernel-100 transition px-2 py-1">Formulas</a>
          <a href={`${base}geometry/`} class="hover:text-kernel-100 transition px-2 py-1">Geometry</a>
          <a href={`${base}rosetta/`} class="hover:text-kernel-100 transition px-2 py-1">Rosetta</a>
          <a href={`${base}ledger/`} class="hover:text-kernel-100 transition px-2 py-1">Ledger</a>
          <span class="text-kernel-700">|</span>
          <!-- Corpus -->
          <a href={`${base}epistemology/`} class="hover:text-kernel-100 transition px-2 py-1">Epistemology</a>
          <a href={`${base}philosophy/`} class="hover:text-kernel-100 transition px-2 py-1">Philosophy</a>
          <span class="text-kernel-700">|</span>
          <a href={`${base}about/`} class="hover:text-kernel-100 transition px-2 py-1">About</a>
          <a href={`${base}papers/`} class="hover:text-kernel-100 transition px-2 py-1">Papers</a>
          <span class="text-kernel-700">|</span>
          <a
            href="https://github.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS"
            class="hover:text-kernel-100 transition px-2 py-1"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-kernel-800 px-6 py-6 mt-20">
      <div class="max-w-6xl mx-auto text-center text-xs text-kernel-500">
        <p><em>Collapsus generativus est; solum quod redit, reale est.</em></p>
        <p class="mt-1">
          Headless Contract Gateway · UMCP v2.2.5 ·
          <a
            href="https://github.com/calebpruett927/GENERATIVE-COLLAPSE-DYNAMICS"
            class="underline hover:text-kernel-300"
            target="_blank"
            rel="noopener"
          >
            Source
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
