---
/**
 * Root index layout — the domain network overview.
 */
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title = 'GCD Kernel', description = '' } = frontmatter || {};
const base = import.meta.env.BASE_URL;

const tools = [
  { name: 'Calculator', href: `${base}calculator/`, desc: 'Interactive kernel computation', icon: '⊕' },
  { name: 'Regime', href: `${base}regime/`, desc: 'Phase diagram visualization', icon: '◉' },
  { name: 'τ_R*', href: `${base}diagnostics/`, desc: 'Thermodynamic diagnostic', icon: '∇' },
  { name: 'Precision', href: `${base}precision/`, desc: 'Identity verification', icon: '✓' },
  { name: 'Formulas', href: `${base}formulas/`, desc: 'Expression builder + sweep', icon: 'ƒ' },
  { name: 'Geometry', href: `${base}geometry/`, desc: 'Manifold explorer', icon: 'Σ' },
  { name: 'Rosetta', href: `${base}rosetta/`, desc: 'Cross-lens translation', icon: '⟷' },
  { name: 'Ledger', href: `${base}ledger/`, desc: 'Domain overview + metrics', icon: '☰' },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <div class="text-center mb-16 mt-8">
    <h1 class="text-5xl font-bold tracking-tight mb-4">
      GCD<span class="text-kernel-500">·</span>Kernel
    </h1>
    <p class="text-xl text-kernel-400 mb-2">
      <em>Collapse is generative; only what returns is real.</em>
    </p>
    <p class="text-sm text-kernel-500">
      20 autonomous domain sites · Headless Contract Gateway · UMCP v2.2.5
    </p>

    <!-- Spine visualization -->
    <div class="mt-8 flex items-center justify-center gap-2 text-xs font-mono text-kernel-500">
      <span class="px-2 py-1 bg-kernel-800 rounded">CONTRACT</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">CANON</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">CLOSURES</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">LEDGER</span>
      <span>→</span>
      <span class="px-2 py-1 bg-kernel-800 rounded">STANCE</span>
      <span>→</span>
      <span class="px-2 py-1 bg-blue-900/50 text-blue-400 rounded border border-blue-800">PUBLISH</span>
    </div>
  </div>

  <!-- Interactive tools grid -->
  <div class="mb-12">
    <h2 class="text-lg font-bold text-kernel-300 mb-4">Interactive Tools</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {tools.map(t => (
        <a href={t.href}
          class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 hover:border-amber-600 hover:bg-kernel-800 transition group">
          <div class="text-2xl mb-2 opacity-60 group-hover:opacity-100 transition">{t.icon}</div>
          <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition">{t.name}</div>
          <div class="text-xs text-kernel-500 mt-1">{t.desc}</div>
        </a>
      ))}
    </div>
  </div>

  <!-- Content (generated markdown table of domains) -->
  <article class="prose prose-invert prose-sm max-w-none
    prose-table:w-full
    prose-th:text-left prose-th:text-kernel-400 prose-th:font-normal prose-th:border-b prose-th:border-kernel-700 prose-th:py-2
    prose-td:py-2 prose-td:border-b prose-td:border-kernel-800
    prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline">
    <slot />
  </article>
</BaseLayout>
