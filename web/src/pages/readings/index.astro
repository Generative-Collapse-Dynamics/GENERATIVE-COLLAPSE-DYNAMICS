---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const readings = [
  {
    title: 'Liber Universalis de Collapsus Mathematica',
    slug: 'liber-collapsus',
    author: 'Clement Paulus',
    date: '11 October 2025',
    language: 'Latin',
    chapters: 8,
    desc: 'The foundational Latin treatise — a single axiom, six invariants, three regimes, and the operational ethics of collapse. Interactive deep reading with live kernel verification, geometric slaughter demos, and regime classification.',
    tags: ['Axiom-0', 'Kernel', 'Regimes', 'Latin'],
    highlight: true,
  },
  {
    title: 'Generative Collapse Dynamics (UMCP/GCD): Enabling Cross-Domain Comparability via Contract-Frozen Kernel Invariants and Typed Return',
    slug: 'gcd-whitepaper',
    author: 'Clement Paulus',
    date: '2025',
    language: 'English',
    chapters: 15,
    desc: 'The complete formal specification — from measured object through kernel, frozen parameters, regime classification, seam budget, return typing, cross-domain patterns, scale ladder, degenerate limits, 44 structural identities, and falsifiable predictions. Interactive deep reading with live kernel verification, seam budget calculator, and regime explorer.',
    tags: ['Kernel', 'Seam Budget', 'Return Typing', 'Scale Ladder', '44 Identities', 'Falsifiable'],
    highlight: true,
  },
];
---

<BaseLayout title="Deep Readings" description="Interactive deep reading pages for published GCD papers — live verification, embedded tools, and contextual commentary">
  <div class="max-w-5xl mx-auto">

    <!-- Hero -->
    <div class="text-center py-16 md:py-24">
      <p class="text-xs uppercase tracking-[0.3em] text-kernel-500 mb-4">Deep Readings</p>
      <h1 class="text-3xl md:text-5xl font-bold text-kernel-100 mb-4 leading-[1.1] tracking-tight">
        Read. Verify. Return.
      </h1>
      <p class="text-kernel-400 max-w-lg mx-auto text-sm leading-relaxed">
        Interactive reading pages for published works — each section pairs the original text
        with English translation, contextual commentary, and live verification tools.
        <em class="text-kernel-500">Intellectus non legitur; computatur.</em>
      </p>
    </div>

    <!-- Readings grid -->
    <div class="space-y-4 mb-16">
      {readings.map(r => (
        <a href={`${base}readings/${r.slug}/`} class="block bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-6 hover:border-amber-500/30 transition group no-underline">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                {r.highlight && <span class="text-[10px] uppercase tracking-wider text-amber-400 bg-amber-500/10 px-2 py-0.5 rounded-full font-bold">Foundational</span>}
                <span class="text-[10px] uppercase tracking-wider text-kernel-600">{r.language}</span>
              </div>
              <h2 class="text-lg font-bold text-kernel-100 group-hover:text-amber-400 transition mb-1 italic font-serif">
                {r.title}
              </h2>
              <p class="text-xs text-kernel-500 mb-3">{r.author} · {r.date} · {r.chapters} chapters</p>
              <p class="text-sm text-kernel-400 leading-relaxed">{r.desc}</p>
              <div class="flex gap-2 mt-3">
                {r.tags.map(t => (
                  <span class="text-[10px] text-kernel-500 bg-kernel-800/50 px-2 py-0.5 rounded">{t}</span>
                ))}
              </div>
            </div>
            <span class="text-kernel-600 group-hover:text-amber-400 transition text-xl mt-2 shrink-0">&rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Coming soon -->
    <div class="bg-kernel-900/30 border border-kernel-800/30 rounded-xl p-8 text-center mb-16">
      <p class="text-xs uppercase tracking-[0.2em] text-kernel-600 mb-3">More readings coming</p>
      <p class="text-sm text-kernel-400 max-w-md mx-auto">
        Deep reading pages for additional published papers across particle physics, consciousness coherence,
        spacetime memory, cross-scale matter, and more are in preparation.
      </p>
    </div>

  </div>
</BaseLayout>
