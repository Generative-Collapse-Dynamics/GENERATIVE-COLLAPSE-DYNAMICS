---
import BaseLayout from '../layouts/BaseLayout.astro';
import PrecisionVerifier from '../components/PrecisionVerifier.astro';
---

<BaseLayout title="Precision Verification — GCD">
  <div class="max-w-5xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Precision Verification</h1>
      <p class="text-kernel-400">
        Verify the three algebraic identities (F + ω = 1, IC ≤ F, IC = exp(κ))
        across thousands of random traces. All computation runs in your browser.
      </p>
    </div>
    <PrecisionVerifier />
  </div>
</BaseLayout>
