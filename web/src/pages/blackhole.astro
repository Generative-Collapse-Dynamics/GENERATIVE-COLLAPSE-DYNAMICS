  /* --- 4. Arrow of Time Chart ------------------------------------ */

  function renderArrowChart() {
    const [canvas, ctx, cssW] = setupCanvas('arrow-canvas', 720, 280);
    const cssH = 280;
    const m = { top: 24, right: 20, bottom: 48, left: 64 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // Compute descent/ascent ratio across ω
    const steps = 500;
    const data: [number, number, number][] = []; // [omega, descent, ascentRatio]
    let maxRatio = 0;
    for (let i = 1; i < steps; i++) {
      const om = (i / steps) * 0.95;
      const dc = descentCost(0.01, om);
      const ratio = arrowAsymmetry(0.01, om);
      data.push([om, dc, ratio]);
      if (ratio < 100) maxRatio = Math.max(maxRatio, ratio);
    }
    const yCap = Math.min(maxRatio, 30);

    const mapX = (w: number) => m.left + (w / 1.0) * plotW;
    const mapY = (r: number) => m.top + (1 - Math.min(r, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 5; i++) {
      const val = yCap - (i / 5) * yCap;
      ctx.fillText(val.toFixed(0), m.left - 5, m.top + (i / 5) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('Ascent/Descent Ratio', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Symmetry line at ratio = 1
    ctx.setLineDash([4, 3]);
    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(m.left, mapY(1)); ctx.lineTo(m.left + plotW, mapY(1)); ctx.stroke();
    ctx.setLineDash([]);

    // Fill under curve
    const grad = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    grad.addColorStop(0, 'rgba(96,165,250,0.15)');
    grad.addColorStop(1, 'rgba(96,165,250,0.01)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(data[0][0]), mapY(1));
    for (const [om, , ratio] of data) ctx.lineTo(mapX(om), mapY(ratio));
    ctx.lineTo(mapX(data[data.length - 1][0]), mapY(1));
    ctx.closePath(); ctx.fill();

    // Ratio curve
    ctx.strokeStyle = '#60a5fa';
    ctx.lineWidth = 2.5;
    ctx.shadowColor = 'rgba(96,165,250,0.4)';
    ctx.shadowBlur = 5;
    ctx.beginPath();
    for (let i = 0; i < data.length; i++) {
      const px = mapX(data[i][0]);
      const py = mapY(data[i][2]);
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Annotations
    ctx.font = '9px ui-monospace, monospace';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.textAlign = 'left';
    ctx.fillText('Ratio = 1: symmetric (no time dilation)', m.left + 5, mapY(1) - 5);
    ctx.fillStyle = 'rgba(96,165,250,0.7)';
    ctx.fillText('Ratio → ∞: escape impossible', m.left + plotW * 0.6, m.top + 16);

    ctx.restore();
  }

  /* --- 5. Tidal Force Chart -------------------------------------- */

  function renderTidalChart() {
    const [canvas, ctx, cssW] = setupCanvas('tidal-canvas', 720, 260);
    const cssH = 260;
    const m = { top: 24, right: 20, bottom: 48, left: 64 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // Compute tidal force
    const data: [number, number][] = [];
    let maxT = 0;
    for (let i = 0; i < 600; i++) {
      const om = (i / 599) * 0.98;
      const t = d2Gamma(om);
      data.push([om, t]);
      if (t < 500) maxT = Math.max(maxT, t);
    }
    const yCap = Math.min(maxT, 200);

    const mapX = (w: number) => m.left + (w / 1.0) * plotW;
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = yCap - (i / 4) * yCap;
      ctx.fillText(val.toFixed(0), m.left - 5, m.top + (i / 4) * plotH + 4);
    }

    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('d²Γ/dω² (Tidal Force)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Fill
    const grad = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    grad.addColorStop(0, 'rgba(168,85,247,0.15)');
    grad.addColorStop(1, 'rgba(168,85,247,0.01)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(data[0][0]), mapY(0));
    for (const [om, t] of data) ctx.lineTo(mapX(om), mapY(t));
    ctx.lineTo(mapX(data[data.length - 1][0]), mapY(0));
    ctx.closePath(); ctx.fill();

    // Curve
    ctx.strokeStyle = '#a855f7';
    ctx.lineWidth = 2.5;
    ctx.shadowColor = 'rgba(168,85,247,0.4)';
    ctx.shadowBlur = 5;
    ctx.beginPath();
    for (let i = 0; i < data.length; i++) {
      const px = mapX(data[i][0]);
      const py = mapY(data[i][1]);
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Spaghettification zone label
    ctx.font = 'bold 10px ui-sans-serif, system-ui, sans-serif';
    ctx.fillStyle = 'rgba(168,85,247,0.6)';
    ctx.textAlign = 'right';
    ctx.fillText('Spaghettification zone →', m.left + plotW - 10, m.top + 18);

    ctx.restore();
  }

  /* --- 6. Gravitational Lensing ---------------------------------- */

  function renderLensing() {
    const [canvas, ctx, cssW] = setupCanvas('lensing-canvas', 420, 420);
    const cssH = 420;
    const cx = cssW / 2;
    const cy = cssH / 2;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    const maxR = Math.min(cssW, cssH) * 0.42;

    // Background stars (dense field)
    for (let i = 0; i < 200; i++) {
      const sx = Math.random() * cssW;
      const sy = Math.random() * cssH;
      const dist = Math.sqrt((sx - cx) ** 2 + (sy - cy) ** 2);
      // Stars near center are dimmer (BH shadow)
      const brightness = dist < maxR * 0.3 ? 0.02 : (0.1 + Math.random() * 0.25);
      ctx.fillStyle = `rgba(255,255,255,${brightness})`;
      ctx.beginPath();
      ctx.arc(sx, sy, Math.random() * 1.3, 0, Math.PI * 2);
      ctx.fill();
    }

    // Gravitational lensing distortion -- background grid warped by BH
    ctx.strokeStyle = 'rgba(100,140,255,0.06)';
    ctx.lineWidth = 0.5;
    const gridSize = 20;
    for (let gx = 0; gx < cssW; gx += gridSize) {
      ctx.beginPath();
      for (let gy = 0; gy <= cssH; gy += 2) {
        const dx = gx - cx, dy = gy - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const deflect = dist > 10 ? maxR * 15 / (dist * dist) : 0;
        const angle = Math.atan2(dy, dx);
        const nx = gx + Math.cos(angle + Math.PI / 2) * deflect;
        const ny = gy + Math.sin(angle + Math.PI / 2) * deflect;
        gy === 0 ? ctx.moveTo(nx, ny) : ctx.lineTo(nx, ny);
      }
      ctx.stroke();
    }
    for (let gy = 0; gy < cssH; gy += gridSize) {
      ctx.beginPath();
      for (let gx = 0; gx <= cssW; gx += 2) {
        const dx = gx - cx, dy = gy - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const deflect = dist > 10 ? maxR * 15 / (dist * dist) : 0;
        const angle = Math.atan2(dy, dx);
        const nx = gx + Math.cos(angle + Math.PI / 2) * deflect;
        const ny = gy + Math.sin(angle + Math.PI / 2) * deflect;
        gx === 0 ? ctx.moveTo(nx, ny) : ctx.lineTo(nx, ny);
      }
      ctx.stroke();
    }

    // BH shadow -- deep radial gradient
    const shadowGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxR * 0.5);
    shadowGrad.addColorStop(0, 'rgba(0,0,0,1)');
    shadowGrad.addColorStop(0.6, 'rgba(0,0,0,0.95)');
    shadowGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = shadowGrad;
    ctx.fillRect(cx - maxR * 0.5, cy - maxR * 0.5, maxR, maxR);

    // Photon sphere glow
    const psGrad = ctx.createRadialGradient(cx, cy, 24, cx, cy, 34);
    psGrad.addColorStop(0, 'rgba(255,200,80,0.0)');
    psGrad.addColorStop(0.4, 'rgba(255,180,60,0.15)');
    psGrad.addColorStop(1, 'rgba(255,150,40,0.0)');
    ctx.fillStyle = psGrad;
    ctx.beginPath();
    ctx.arc(cx, cy, 34, 0, Math.PI * 2);
    ctx.fill();

    // Event horizon circle
    ctx.beginPath();
    ctx.arc(cx, cy, 16, 0, Math.PI * 2);
    ctx.fillStyle = '#000';
    ctx.fill();
    ctx.strokeStyle = 'rgba(239,68,68,0.6)';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Photon sphere ring
    ctx.beginPath();
    ctx.arc(cx, cy, 27, 0, Math.PI * 2);
    ctx.setLineDash([3, 3]);
    ctx.strokeStyle = 'rgba(255,200,80,0.5)';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.setLineDash([]);

    // Lensing arcs for each entity
    const colors = ['#ef4444', '#f97316', '#a855f7', '#34d399', '#60a5fa', '#ec4899'];
    entityData.forEach((ed, i) => {
      const delta = ed.kernel.delta;
      if (delta < EPSILON) return;

      const wd = wellDepth(ed.kernel.kappa);
      const defl = deflectionAngle(delta, wd);
      const morphology = classifyLensing(delta);

      // Ring radius inversely proportional to delta
      const ringR = Math.min(maxR * 0.9, 30 + (1 / (delta + 0.05)) * 15);

      const color = colors[i % colors.length];

      if (morphology === 'perfect_ring') {
        // Full ring
        ctx.beginPath();
        ctx.arc(cx, cy, ringR, 0, Math.PI * 2);
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.globalAlpha = 0.7;
        ctx.stroke();
        ctx.globalAlpha = 1;
      } else if (morphology === 'thick_arc') {
        // Arc ~ 270deg
        const startAngle = -Math.PI * 0.75 + i * 0.4;
        ctx.beginPath();
        ctx.arc(cx, cy, ringR, startAngle, startAngle + Math.PI * 1.5);
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;
        ctx.globalAlpha = 0.6;
        ctx.stroke();
        ctx.globalAlpha = 1;
      } else if (morphology === 'thin_arc') {
        // Arc ~ 120deg
        const startAngle = -Math.PI * 0.3 + i * 0.6;
        ctx.beginPath();
        ctx.arc(cx, cy, ringR, startAngle, startAngle + Math.PI * 0.67);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.globalAlpha = 0.5;
        ctx.stroke();
        ctx.globalAlpha = 1;
      } else {
        // Distorted -- small scattered dots
        for (let j = 0; j < 5; j++) {
          const angle = (j / 5) * Math.PI * 2 + i * 0.8;
          const jitter = (Math.random() - 0.5) * 15;
          ctx.beginPath();
          ctx.arc(cx + Math.cos(angle) * (ringR + jitter), cy + Math.sin(angle) * (ringR + jitter), 2, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.globalAlpha = 0.4;
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }
    });

    // Center label
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = 'bold 9px ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.fillText('BH', cx, cy + 3);

    // Lensing info panel
    const infoEl = document.getElementById('lensing-info')!;
    const lensingLabels: Record<string, string> = {
      perfect_ring: 'Einstein Ring — nearly perfect symmetry',
      thick_arc: 'Strong Arc — 270° lensing arc',
      thin_arc: 'Thin Arc — partial deflection',
      distorted: 'Weak Distortion — scattered images',
    };

    let infoHtml = '<h3 class="text-sm font-bold text-kernel-300 mb-2">Lensing by Entity</h3>';
    entityData.forEach((ed, i) => {
      const delta = ed.kernel.delta;
      const wd = wellDepth(ed.kernel.kappa);
      const defl = deflectionAngle(delta, wd);
      const morphology = classifyLensing(delta);
      const color = colors[i % colors.length];

      infoHtml += `
        <div class="bg-kernel-800 border border-kernel-700 rounded p-2">
          <div class="flex items-center gap-2 mb-1">
            <span class="inline-block w-2 h-2 rounded-full" style="background:${color}"></span>
            <span class="text-kernel-300 font-bold">${ed.entity.name}</span>
          </div>
          <div class="text-kernel-500 grid grid-cols-3 gap-x-2 font-mono text-[10px]">
            <span>Δ = ${delta.toFixed(4)}</span>
            <span>|κ| = ${wd.toFixed(2)}</span>
            <span>theta = ${fmtV(defl)}deg</span>
          </div>
          <div class="text-kernel-400 text-[10px] mt-1">${lensingLabels[morphology]}</div>
        </div>`;
    });
    infoEl.innerHTML = infoHtml;
  }

  /* --- 7. Frame-Dragging Chart --------------------------------- */

  function renderFrameDrag() {
    const [canvas, ctx, cssW] = setupCanvas('framedrag-canvas', 720, 280);
    const cssH = 280;
    const m = { top: 24, right: 20, bottom: 48, left: 64 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    const spins = [0.3, 0.5, 0.7, 0.9, 0.998];
    const spinColors = ['#60a5fa', '#34d399', '#fbbf24', '#f97316', '#ef4444'];
    const yCap = 8;

    const mapX = (w: number) => m.left + (w / 1.0) * plotW;
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = yCap - (i / 4) * yCap;
      ctx.fillText(val.toFixed(0), m.left - 5, m.top + (i / 4) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('ω_drag (Frame-Dragging)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Curves for each spin
    spins.forEach((spin, si) => {
      const isActive = Math.abs(spin - currentSpin) < 0.05;
      ctx.strokeStyle = spinColors[si];
      ctx.lineWidth = isActive ? 3.5 : 1.5;
      ctx.globalAlpha = isActive ? 1.0 : 0.4;
      ctx.beginPath();
      for (let i = 0; i < 600; i++) {
        const om = (i / 599) * 0.95;
        const fd = frameDragging(om, spin);
        const px = mapX(om);
        const py = mapY(fd);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.globalAlpha = 1.0;

      // Label at end
      const labelOm = 0.85 - si * 0.06;
      const labelFd = frameDragging(labelOm, spin);
      if (labelFd < yCap) {
        ctx.fillStyle = spinColors[si];
        ctx.font = isActive ? 'bold 10px ui-monospace, monospace' : '9px ui-monospace, monospace';
        ctx.textAlign = 'left';
        ctx.fillText(`a*=${spin}${isActive ? ' ◀' : ''}`, mapX(labelOm) + 4, mapY(labelFd) - 4);
      }
    });

    // Current spin curve (if not matching a preset)
    if (!spins.some(s => Math.abs(s - currentSpin) < 0.05)) {
      ctx.strokeStyle = '#e879f9';
      ctx.lineWidth = 3;
      ctx.setLineDash([5, 3]);
      ctx.beginPath();
      for (let i = 0; i < 600; i++) {
        const om = (i / 599) * 0.95;
        const fd = frameDragging(om, currentSpin);
        const px = mapX(om);
        const py = mapY(fd);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.setLineDash([]);

      // Label
      const labelFd = frameDragging(0.6, currentSpin);
      if (labelFd < yCap) {
        ctx.fillStyle = '#e879f9';
        ctx.font = 'bold 10px ui-monospace, monospace';
        ctx.textAlign = 'left';
        ctx.fillText(`a*=${currentSpin.toFixed(3)} (current)`, mapX(0.6) + 4, mapY(labelFd) - 4);
      }
    }

    // Entity markers at current spin
    for (const ed of entityData) {
      const ew = ed.kernel.omega;
      const fd = frameDragging(ew, currentSpin);
      if (ew < 0.95 && fd < yCap) {
        ctx.beginPath();
        ctx.arc(mapX(ew), mapY(fd), 3.5, 0, Math.PI * 2);
        ctx.fillStyle = regimeColor(ed.regime);
        ctx.fill();
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    ctx.restore();
  }

  /* --- 8. Penrose Process Chart ---------------------------------- */

  function renderPenrose() {
    const [canvas, ctx, cssW] = setupCanvas('penrose-canvas', 720, 280);
    const cssH = 280;
    const m = { top: 24, right: 20, bottom: 48, left: 64 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    const yCap = 0.45;
    const mapX = (s: number) => m.left + (s / 1.0) * plotW;
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = (yCap - (i / 4) * yCap) * 100;
      ctx.fillText(val.toFixed(0) + '%', m.left - 5, m.top + (i / 4) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('a* (Spin Parameter)', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('Efficiency', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Penrose efficiency
    const gradP = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    gradP.addColorStop(0, 'rgba(236,72,153,0.12)');
    gradP.addColorStop(1, 'rgba(236,72,153,0.01)');
    ctx.fillStyle = gradP;
    ctx.beginPath();
    ctx.moveTo(mapX(0), mapY(0));
    for (let i = 0; i < 500; i++) {
      const spin = (i / 499) * 0.999;
      ctx.lineTo(mapX(spin), mapY(penroseEfficiency(spin)));
    }
    ctx.lineTo(mapX(0.999), mapY(0));
    ctx.closePath(); ctx.fill();

    ctx.strokeStyle = '#ec4899';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    for (let i = 0; i < 500; i++) {
      const spin = (i / 499) * 0.999;
      const eff = penroseEfficiency(spin);
      i === 0 ? ctx.moveTo(mapX(spin), mapY(eff)) : ctx.lineTo(mapX(spin), mapY(eff));
    }
    ctx.stroke();

    // Radiative efficiency
    const gradR = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    gradR.addColorStop(0, 'rgba(249,115,22,0.10)');
    gradR.addColorStop(1, 'rgba(249,115,22,0.01)');
    ctx.fillStyle = gradR;
    ctx.beginPath();
    ctx.moveTo(mapX(0), mapY(0));
    for (let i = 0; i < 500; i++) {
      const spin = (i / 499) * 0.999;
      ctx.lineTo(mapX(spin), mapY(radiativeEfficiency(spin)));
    }
    ctx.lineTo(mapX(0.999), mapY(0));
    ctx.closePath(); ctx.fill();

    ctx.strokeStyle = '#f97316';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    for (let i = 0; i < 500; i++) {
      const spin = (i / 499) * 0.999;
      const eff = radiativeEfficiency(spin);
      i === 0 ? ctx.moveTo(mapX(spin), mapY(eff)) : ctx.lineTo(mapX(spin), mapY(eff));
    }
    ctx.stroke();

    // Legend
    ctx.font = '10px ui-monospace, monospace';
    ctx.fillStyle = '#ec4899';
    ctx.textAlign = 'left';
    ctx.fillText('η_P (Penrose)', m.left + 10, m.top + 14);
    ctx.fillStyle = '#f97316';
    ctx.fillText('η_rad (Radiative)', m.left + 10, m.top + 28);

    // Max Penrose annotation
    ctx.fillStyle = 'rgba(236,72,153,0.7)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'right';
    ctx.fillText('Max η_P ~= 29.3% (Kerr)', mapX(0.95), mapY(penroseEfficiency(0.999)) + 14);

    // Current spin marker
    const penCur = penroseEfficiency(currentSpin);
    const radCur = radiativeEfficiency(currentSpin);
    ctx.setLineDash([3, 3]);
    ctx.strokeStyle = 'rgba(255,255,255,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(mapX(currentSpin), m.top); ctx.lineTo(mapX(currentSpin), m.top + plotH); ctx.stroke();
    ctx.setLineDash([]);
    // Penrose dot
    ctx.beginPath();
    ctx.arc(mapX(currentSpin), mapY(penCur), 5, 0, Math.PI * 2);
    ctx.fillStyle = '#ec4899'; ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
    // Radiative dot
    ctx.beginPath();
    ctx.arc(mapX(currentSpin), mapY(radCur), 5, 0, Math.PI * 2);
    ctx.fillStyle = '#f97316'; ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
    // Label
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 9px ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.fillText(`a*=${currentSpin.toFixed(3)}`, mapX(currentSpin), m.top + plotH + 30);

    ctx.restore();
  }

  /* --- 9. Proper Time Dilation Chart ----------------------------- */

  function renderTimeDilation() {
    const [canvas, ctx, cssW] = setupCanvas('timedilation-canvas', 360, 280);
