    ctx.fillText('dτ/dt', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Fill
    const grad = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    grad.addColorStop(0, 'rgba(52,211,153,0.12)');
    grad.addColorStop(1, 'rgba(239,68,68,0.12)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(0), mapY(0));
    for (let i = 0; i <= 600; i++) {
      const om = (i / 600) * 0.999;
      ctx.lineTo(mapX(om), mapY(properTimeFactor(om)));
    }
    ctx.lineTo(mapX(0.999), mapY(0));
    ctx.closePath(); ctx.fill();

    // Curve
    ctx.strokeStyle = '#34d399';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    for (let i = 0; i <= 600; i++) {
      const om = (i / 600) * 0.999;
      const pt = properTimeFactor(om);
      i === 0 ? ctx.moveTo(mapX(om), mapY(pt)) : ctx.lineTo(mapX(om), mapY(pt));
    }
    ctx.stroke();

    // Entity dots
    for (const ed of entityData) {
      const pt = properTimeFactor(ed.kernel.omega);
      ctx.beginPath();
      ctx.arc(mapX(ed.kernel.omega), mapY(pt), 3.5, 0, Math.PI * 2);
      ctx.fillStyle = regimeColor(ed.regime);
      ctx.fill();
      ctx.strokeStyle = '#000';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Annotation
    ctx.fillStyle = 'rgba(52,211,153,0.7)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillText('Time freezes at ω → 1', m.left + 5, m.top + plotH - 10);

    ctx.restore();
  }

  /* --- 10. BH Entropy Chart ------------------------------------- */

  function renderEntropy() {
    const [canvas, ctx, cssW] = setupCanvas('entropy-canvas', 360, 280);
    const cssH = 280;
    const m = { top: 24, right: 16, bottom: 48, left: 56 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // Compute entropy over kappa range
    const data: [number, number][] = [];
    let maxE = 0;
    for (let i = 0; i <= 400; i++) {
      const kap = -(i / 400) * 8; // κ ranges from 0 to -8
      const e = bhEntropy(kap);
      data.push([kap, e]);
      maxE = Math.max(maxE, e);
    }
    const yCap = Math.min(maxE * 1.1, 6);

    const mapX = (k: number) => m.left + ((k + 8) / 8) * plotW; // -8 on left, 0 on right
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 8; i++) {
      const x = m.left + (i / 8) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 4; i++) {
      const kap = -8 + (i / 4) * 8;
      ctx.fillText(kap.toFixed(0), m.left + (i / 4) * plotW, m.top + plotH + 16);
    }
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = yCap - (i / 4) * yCap;
      ctx.fillText(val.toFixed(1), m.left - 5, m.top + (i / 4) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('κ (Log-Integrity)', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(12, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('S_BH = κ²/(4π)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Fill
    const grad = ctx.createLinearGradient(m.left, 0, m.left + plotW, 0);
    grad.addColorStop(0, 'rgba(168,85,247,0.15)');
    grad.addColorStop(1, 'rgba(168,85,247,0.02)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(data[0][0]), mapY(0));
    for (const [k, e] of data) ctx.lineTo(mapX(k), mapY(e));
    ctx.lineTo(mapX(data[data.length - 1][0]), mapY(0));
    ctx.closePath(); ctx.fill();

    // Curve
    ctx.strokeStyle = '#a855f7';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    for (let i = 0; i < data.length; i++) {
      const px = mapX(data[i][0]);
      const py = mapY(data[i][1]);
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.stroke();

    // Entity markers
    for (const ed of entityData) {
      const kap = ed.kernel.kappa;
      const e = bhEntropy(kap);
      if (kap >= -8) {
        ctx.beginPath();
        ctx.arc(mapX(kap), mapY(e), 3.5, 0, Math.PI * 2);
        ctx.fillStyle = regimeColor(ed.regime);
        ctx.fill();
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    // Annotation
    ctx.fillStyle = 'rgba(168,85,247,0.7)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillText('S_BH ∼ κ² (area law analog)', m.left + 5, m.top + 14);

    ctx.restore();
  }

  /* --- 11. Orbital Precession Chart ------------------------------ */

  function renderPrecession() {
    const [canvas, ctx, cssW] = setupCanvas('precession-canvas', 360, 280);
    const cssH = 280;
    const m = { top: 24, right: 16, bottom: 48, left: 56 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    const data: [number, number][] = [];
    let maxP = 0;
    for (let i = 0; i < 600; i++) {
      const om = (i / 599) * 0.7;
      const p = orbitalPrecession(om);
      data.push([om, p]);
      if (p < 200) maxP = Math.max(maxP, p);
    }
    const yCap = Math.min(maxP * 1.1, 50);

    const mapX = (w: number) => m.left + (w / 0.8) * plotW;
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 8; i++) {
      const x = m.left + (i / 8) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 8; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = yCap - (i / 4) * yCap;
      ctx.fillText(val.toFixed(0), m.left - 5, m.top + (i / 4) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(12, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('δφ (rad/orbit)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Fill
    const grad = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    grad.addColorStop(0, 'rgba(251,191,36,0.12)');
    grad.addColorStop(1, 'rgba(251,191,36,0.01)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(data[0][0]), mapY(0));
    for (const [om, p] of data) ctx.lineTo(mapX(om), mapY(p));
    ctx.lineTo(mapX(data[data.length - 1][0]), mapY(0));
    ctx.closePath(); ctx.fill();

    ctx.strokeStyle = '#fbbf24';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    for (let i = 0; i < data.length; i++) {
      i === 0 ? ctx.moveTo(mapX(data[i][0]), mapY(data[i][1])) : ctx.lineTo(mapX(data[i][0]), mapY(data[i][1]));
    }
    ctx.stroke();

    // Entity dots
    for (const ed of entityData) {
      const om = ed.kernel.omega;
      if (om <= 0.7) {
        const p = orbitalPrecession(om);
        if (p < yCap) {
          ctx.beginPath();
          ctx.arc(mapX(om), mapY(p), 3.5, 0, Math.PI * 2);
          ctx.fillStyle = regimeColor(ed.regime);
          ctx.fill();
          ctx.strokeStyle = '#000';
          ctx.lineWidth = 1;
          ctx.stroke();
        }
      }
    }

    // Annotation
    ctx.fillStyle = 'rgba(251,191,36,0.7)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillText('δφ = 6πω²/(1−ω)²', m.left + 5, m.top + 14);

    ctx.restore();
  }

  /* --- 12. GW Strain Chart --------------------------------------- */

  function renderGWStrain() {
    const [canvas, ctx, cssW] = setupCanvas('gwstrain-canvas', 360, 280);
    const cssH = 280;
    const m = { top: 24, right: 16, bottom: 48, left: 56 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // GW strain for different C values at observer distance
    const dist = currentDistance;
    const cVals = [0.2, 0.4, 0.6, 0.8];
    const cColors = ['#60a5fa', '#34d399', '#fbbf24', '#ef4444'];
    let maxH = 0;
    for (const cv of cVals) {
      for (let i = 0; i < 600; i++) {
        const om = (i / 599) * 0.95;
        maxH = Math.max(maxH, gwStrain(om, cv, dist));
      }
    }
    const yCap = Math.min(maxH * 1.1, 4);

    const mapX = (w: number) => m.left + (w / 1.0) * plotW;
    const mapY = (v: number) => m.top + (1 - Math.min(v, yCap) / yCap) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 16);
    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = yCap - (i / 4) * yCap;
      ctx.fillText(val.toFixed(1), m.left - 5, m.top + (i / 4) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω', m.left + plotW / 2, cssH - 6);
    ctx.save(); ctx.translate(12, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('h (GW Strain)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Curves for each C value
    cVals.forEach((cv, ci) => {
      ctx.strokeStyle = cColors[ci];
      ctx.lineWidth = 2;
      ctx.beginPath();
      for (let i = 0; i < 600; i++) {
        const om = (i / 599) * 0.95;
        const h = gwStrain(om, cv, dist);
        i === 0 ? ctx.moveTo(mapX(om), mapY(h)) : ctx.lineTo(mapX(om), mapY(h));
      }
      ctx.stroke();

      // Label
      ctx.fillStyle = cColors[ci];
      ctx.font = '9px ui-monospace, monospace';
      ctx.textAlign = 'right';
      const lom = 0.6;
      const lh = gwStrain(lom, cv, dist);
      if (lh < yCap) ctx.fillText(`C=${cv}`, mapX(lom) - 3, mapY(lh) - 4);
    });

    // Entity markers
    for (const ed of entityData) {
      const om = ed.kernel.omega;
      const h = gwStrain(om, ed.kernel.C, dist);
      if (om < 0.95 && h < yCap) {
        ctx.beginPath();
        ctx.arc(mapX(om), mapY(h), 3.5, 0, Math.PI * 2);
        ctx.fillStyle = regimeColor(ed.regime);
        ctx.fill();
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    // Annotation
    ctx.fillStyle = 'rgba(96,165,250,0.7)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillText(`h = Γ²·C/d  (d=${dist.toFixed(1)})`, m.left + 5, m.top + 14);

    ctx.restore();
  }

  /* --- Render All ------------------------------------------------- */

  function renderAll() {
    renderInfall();
    renderSurface();
    renderEntityCards();
    renderArrowChart();
    renderTidalChart();
    renderLensing();
    renderFrameDrag();
    renderPenrose();
    renderTimeDilation();
    renderEntropy();
    renderPrecession();
    renderGWStrain();
  }

  /* --- Initial Render + Event Binding ---------------------------- */

  const infallSlider = document.getElementById('infall-omega') as HTMLInputElement;
  infallSlider.addEventListener('input', renderInfall);

  // Init WebGL 3D gravity well
  const glCanvas = document.getElementById('gl-canvas') as HTMLCanvasElement;
  let gl3d: { destroy: () => void } | null = null;
  if (glCanvas) {
    gl3d = initBlackHole3D(glCanvas);
  }

  // Init controls and render everything
  initControls();

  // Re-render on resize
  let resizeTimer: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(renderAll, 200);
  });
</script>
