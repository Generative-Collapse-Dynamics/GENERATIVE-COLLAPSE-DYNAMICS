---
/**
 * Black Hole Simulation — GCD Gravitational Analogs
 *
 * Maps GCD kernel invariants to black hole physics:
 *   Event horizon  = ω → 1 pole (Γ → ∞)
 *   Gravity        = dΓ/dω (gradient of drift cost)
 *   Mass           = accumulated |κ| (well depth)
 *   Tidal force    = d²Γ/dω² (curvature of cost surface)
 *   Lensing        = deflection from heterogeneity gap Δ
 *   Time dilation  = descent/ascent cost asymmetry
 *
 * All quantities computed client-side from the frozen kernel.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Black Hole Simulation — GCD">
  <div class="max-w-6xl mx-auto">
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- HERO                                                       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <h1 class="text-3xl font-bold text-kernel-100">Black Hole Simulation</h1>
        <span class="text-[10px] font-mono text-kernel-500 border border-kernel-700 rounded px-2 py-0.5">Tier-2 · Spacetime Memory</span>
      </div>
      <p class="text-kernel-300 max-w-3xl leading-relaxed">
        A black hole in GCD is the <strong class="text-red-400">Γ(ω→1) pole</strong> — the structural boundary
        where drift cost diverges and return becomes impossible (τ_R = ∞_rec). The event horizon is not
        imported from general relativity; it is <em class="text-kernel-200">derived independently</em> from
        Axiom-0 as the point where no signal can return.
      </p>
      <p class="text-kernel-500 italic text-sm mt-2">
        Collapsus generativus est; solum quod redit, reale est. — At the horizon, nothing returns.
      </p>
      <div class="flex flex-wrap gap-3 mt-4">
        <a href={`${base}space/`}
           class="inline-block px-4 py-2 bg-blue-900/50 border border-blue-700/50 rounded-lg text-blue-300 text-sm hover:bg-blue-800/50 hover:border-blue-600 transition">
           Launch Immersive 3D Simulator →
        </a>
        <a href="#section-nav"
           class="inline-block px-4 py-2 bg-kernel-800/50 border border-kernel-700/50 rounded-lg text-kernel-300 text-sm hover:bg-kernel-700/50 transition">
           Jump to Section ↓
        </a>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SCENARIO CONTROLS                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="bg-kernel-900/80 border border-kernel-700 rounded-lg p-4 sm:p-5 mb-6 sticky top-16 z-30 backdrop-blur-md" id="control-panel">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 items-end gap-3 sm:gap-5">
        <!-- Scenario Selector -->
        <div class="sm:col-span-2 lg:col-span-1">
          <label class="text-[11px] text-kernel-400 uppercase tracking-wider block mb-1.5">Scenario</label>
          <select id="scenario-select" class="w-full bg-kernel-800 border border-kernel-600 text-kernel-200 rounded px-3 py-1.5 text-sm focus:border-blue-500 focus:outline-none">
            <option value="stellar">Stellar Black Hole (3–20 M☉)</option>
            <option value="supermassive">Sgr A* — Supermassive (4.15×10⁶ M☉)</option>
            <option value="kerr" selected>Kerr — Rotating (a* ≈ 0.998)</option>
            <option value="binary">Binary BH Merger (LIGO inspiral)</option>
            <option value="primordial">Primordial Black Hole (10¹⁵ g)</option>
            <option value="charged">Reissner-Nordström (charged)</option>
            <option value="custom">Custom — Build Your Own</option>
          </select>
        </div>

        <!-- Spin Parameter -->
        <div>
          <label class="text-[11px] text-kernel-400 uppercase tracking-wider block mb-1.5">Spin a*</label>
          <div class="flex items-center gap-2">
            <input id="spin-slider" type="range" min="0" max="0.998" step="0.001" value="0.700"
                   class="flex-1 accent-purple-500" />
            <span id="spin-val" class="text-sm font-mono text-kernel-200 w-12 text-right">0.700</span>
          </div>
        </div>

        <!-- Observer Distance -->
        <div>
          <label class="text-[11px] text-kernel-400 uppercase tracking-wider block mb-1.5">Distance d</label>
          <div class="flex items-center gap-2">
            <input id="dist-slider" type="range" min="0.1" max="10" step="0.1" value="1.0"
                   class="flex-1 accent-teal-500" />
            <span id="dist-val" class="text-sm font-mono text-kernel-200 w-10 text-right">1.0</span>
          </div>
        </div>

        <!-- Live Readout -->
        <div class="bg-kernel-800/60 border border-kernel-700 rounded px-3 py-1.5 sm:col-span-2 lg:col-span-1">
          <div class="text-[10px] text-kernel-500 uppercase tracking-wider mb-0.5">Active Entity Kernel</div>
          <div class="flex gap-3 text-xs font-mono">
            <span class="text-green-400" id="ro-F">F=—</span>
            <span class="text-red-400" id="ro-omega">ω=—</span>
            <span class="text-blue-400" id="ro-IC">IC=—</span>
            <span class="text-amber-400" id="ro-delta">Δ=—</span>
          </div>
        </div>
      </div>

      <!-- Custom BH Builder (hidden by default) -->
      <div id="custom-builder" class="hidden mt-4 pt-4 border-t border-kernel-700">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-sm text-kernel-300 font-medium">Custom Trace Vector</span>
          <span class="text-[10px] text-kernel-500">(8 channels, each ∈ [0, 1])</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="custom-channels"></div>
      </div>

      <!-- Scenario Description -->
      <div id="scenario-desc" class="mt-3 pt-3 border-t border-kernel-700/50 text-xs text-kernel-400 leading-relaxed"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SECTION NAV                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <nav id="section-nav" class="bg-kernel-900 border border-kernel-700 rounded-lg p-3 sm:p-4 mb-6 scroll-mt-24">
      <div class="text-[11px] text-kernel-500 uppercase tracking-wider mb-2">Sections</div>
      <div class="flex flex-nowrap sm:flex-wrap gap-2 text-xs overflow-x-auto pb-1 -mx-1 px-1 scrollbar-thin">
        <a href="#sec-translation" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">0 · Translation</a>
        <a href="#sec-well" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">1 · Gravity Well</a>
        <a href="#sec-infall" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">2 · Infall</a>
        <a href="#sec-surface" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">3 · Surface</a>
        <a href="#sec-entities" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">4 · Entities</a>
        <a href="#sec-arrow" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">5 · Arrow</a>
        <a href="#sec-tidal" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">6 · Tidal</a>
        <a href="#sec-lensing" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">7 · Lensing</a>
        <a href="#sec-framedrag" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">8 · Frame-Drag</a>
        <a href="#sec-penrose" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">9 · Penrose</a>
        <a href="#sec-proper" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">10 · Time Dil.</a>
        <a href="#sec-gw" class="whitespace-nowrap text-kernel-300 hover:text-kernel-100 bg-kernel-800 px-2.5 py-1 rounded border border-kernel-700 hover:border-kernel-500 transition">11 · GW</a>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §0  GR ↔ GCD Translation Table                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-translation" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-5 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-3">
        <span class="text-xs font-mono text-kernel-500">§0</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">GR ↔ GCD Translation</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Translatio inter campos</span>
      </div>
      <details>
        <summary class="text-xs text-kernel-400 cursor-pointer hover:text-kernel-200 mb-3 select-none">
          Every gravitational concept maps to a GCD kernel quantity. Click to expand the full table.
        </summary>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="border-b border-kernel-700 text-kernel-400">
                <th class="pr-4 py-2">GR Concept</th>
                <th class="pr-4 py-2">GCD Analog</th>
                <th class="py-2">Formula</th>
              </tr>
            </thead>
            <tbody class="text-kernel-300 font-mono text-xs">
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Event Horizon</td><td class="pr-4 py-2">ω → 1 pole</td><td class="py-2">Γ(ω) = ω³/(1−ω+ε) → ∞</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Gravitational Field</td><td class="pr-4 py-2">dΓ/dω</td><td class="py-2">Gradient of drift cost</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Mass</td><td class="pr-4 py-2">|κ| well depth</td><td class="py-2">Accumulated log-integrity</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Tidal Force</td><td class="pr-4 py-2">d²Γ/dω²</td><td class="py-2">Cost curvature (spaghettification)</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Gravitational Lensing</td><td class="pr-4 py-2">Δ = F − IC</td><td class="py-2">Heterogeneity gap deflects trajectories</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Ascent/Descent Asymmetry</td><td class="pr-4 py-2">Cost ratio → ∞</td><td class="py-2">Escape cost / infall cost diverges near horizon</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Hawking Temperature</td><td class="pr-4 py-2">T_H = 1/(8π|κ|)</td><td class="py-2">Inverse well depth — shallow wells radiate hotter</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Gravitational Redshift</td><td class="pr-4 py-2">z = Γ/(1+Γ)</td><td class="py-2">Photon energy loss escaping the well</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">ISCO</td><td class="pr-4 py-2">ω ≈ 0.50</td><td class="py-2">Innermost stable circular orbit — tidal destabilization</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Photon Sphere</td><td class="pr-4 py-2">ω ≈ 0.65</td><td class="py-2">Unstable circular photon orbits</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Frame-Dragging</td><td class="pr-4 py-2">ω_drag(ω, a*)</td><td class="py-2">Lense-Thirring: a*·Γ(ω)/(1+Γ)²</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Ergosphere</td><td class="pr-4 py-2">ω > ω_ergo</td><td class="py-2">Region where frame-dragging exceeds orbit speed</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Penrose Process</td><td class="pr-4 py-2">η_P(a*)</td><td class="py-2">1 − √((1+√(1−a*²))/2) — up to 29.3%</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">BH Entropy</td><td class="pr-4 py-2">S_BH = 4πκ²</td><td class="py-2">Bekenstein analog — area law from log-integrity</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Orbital Precession</td><td class="pr-4 py-2">δφ(ω)</td><td class="py-2">6πΓ(ω)/(1+Γ)² — perihelion advance</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">GW Strain</td><td class="pr-4 py-2">h(ω, C, d)</td><td class="py-2">Γ²·C/d — quadrupole radiation</td></tr>
              <tr class="border-b border-kernel-800"><td class="pr-4 py-2 text-kernel-400 font-sans">Proper Time Dilation</td><td class="pr-4 py-2">dτ/dt</td><td class="py-2">√(1 − 2Γ/(1+Γ)) — clocks freeze at horizon</td></tr>
              <tr><td class="pr-4 py-2 text-kernel-400 font-sans">Radiative Efficiency</td><td class="pr-4 py-2">η_rad(a*)</td><td class="py-2">1 − E_ISCO — up to 42% at extremal spin</td></tr>
            </tbody>
          </table>
        </div>
      </details>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §1  3D Gravity Well (WebGL)                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-well" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§1</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">3D Gravity Well</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Puteus gravitatis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The budget surface Γ(ω) rendered as a 3D funnel. The center plunges toward the event
        horizon where cost diverges and τ_R = ∞_rec. The luminous band is the accretion disk;
        particles spiral inward on Kepler-like trajectories.
        <span class="text-kernel-300">Drag to rotate · Scroll to zoom · Double-click to reset.</span>
      </p>
      <div class="relative">
        <canvas id="gl-canvas" class="w-full rounded" style="height: 520px; cursor: grab;"></canvas>
        <div class="absolute top-3 left-3 flex flex-col gap-1">
          <div class="text-[10px] text-kernel-500 bg-kernel-900/85 px-2 py-1 rounded border border-kernel-800">
            <span class="text-teal-400">●</span> Stable &nbsp;
            <span class="text-amber-400">●</span> Watch &nbsp;
            <span class="text-red-400">●</span> Collapse
          </div>
        </div>
        <div class="absolute bottom-3 right-3 text-[10px] text-kernel-600 bg-kernel-900/85 px-2 py-1 rounded border border-kernel-800">
          WebGL · 96×128 mesh · 250 particles · 500 stars
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §2  Gravitational Infall                                   -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-infall" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§2</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Gravitational Infall</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Casus gravitatis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        Slide ω toward 1.0 to fall toward the event horizon. Drift cost Γ, tidal force d²Γ/dω²,
        and escape ratio all diverge at the boundary. The three regime zones are shaded:
        Stable (ω &lt; 0.038), Watch (0.038 ≤ ω &lt; 0.30), and Collapse (ω ≥ 0.30).
      </p>

      <div class="flex flex-wrap items-center gap-4 mb-4">
        <div class="flex-1 min-w-[200px]">
          <label class="text-xs text-kernel-400 block mb-1">ω — Radial Position → Horizon</label>
          <input id="infall-omega" type="range" min="0" max="0.995" step="0.001" value="0.10" class="w-full accent-red-500" />
          <div class="flex justify-between text-[10px] text-kernel-600 mt-1">
            <span>Safe (ω=0)</span>
            <span class="text-green-500">Stable</span>
            <span class="text-amber-500">Watch</span>
            <span class="text-red-500">Collapse</span>
            <span>Horizon (ω→1)</span>
          </div>
        </div>
        <div class="text-right min-w-[120px]">
          <div class="text-2xl font-mono font-bold" id="infall-omega-val">0.100</div>
          <div class="text-xs text-kernel-500" id="infall-regime">STABLE</div>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4" id="infall-metrics"></div>

      <div class="relative">
        <canvas id="infall-canvas" class="cursor-crosshair" style="max-width: 720px; height: 300px; width: 100%;"></canvas>
        <div id="infall-tooltip" class="hidden absolute text-xs font-mono bg-kernel-800/95 border border-kernel-600 text-kernel-200 px-2 py-1 rounded shadow-lg pointer-events-none z-10 whitespace-nowrap"></div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §3  Budget Surface Heatmap                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-surface" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§3</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Budget Surface</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Superficies impensae</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The full cost landscape over (ω, C). Height = Γ(ω) + α·C. Objects deeper in the
        potential well have higher ω; the dark ridge at ω → 1 is the event horizon.
        Entity positions are marked with regime-colored dots.
      </p>
      <div class="flex flex-col md:flex-row gap-4 items-start">
        <div class="relative">
          <canvas id="surface-canvas" style="width: 400px; height: 400px;"></canvas>
          <div id="surface-tooltip" class="hidden absolute text-xs font-mono bg-kernel-800/95 border border-kernel-600 text-kernel-200 px-2 py-1 rounded shadow-lg pointer-events-none z-10 whitespace-nowrap"></div>
        </div>
        <div class="flex-1">
          <h3 class="text-sm font-bold text-kernel-300 mb-2">Entity Positions</h3>
          <div id="entity-legend" class="space-y-1 text-xs"></div>
          <div class="mt-4 pt-3 border-t border-kernel-700">
            <h3 class="text-sm font-bold text-kernel-300 mb-2">Color Scale</h3>
            <div class="flex items-center gap-2">
              <div class="h-3 flex-1 rounded" style="background: linear-gradient(to right, #0f172a, #1e3a5f, #065f46, #854d0e, #7f1d1d, #ef4444)"></div>
            </div>
            <div class="flex justify-between text-[10px] text-kernel-600 mt-1">
              <span>Low cost</span>
              <span>High cost (horizon)</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §4  Entity Kernel Comparison                               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-entities" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§4</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Entity Kernel Comparison</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Comparatio entium</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        Each spacetime entity passes through the GCD kernel K: [0,1]ⁿ × Δⁿ → (F, ω, S, C, κ, IC).
        The six invariants determine the regime; the heterogeneity gap Δ = F − IC is the
        lensing diagnostic. Cards update when you change the scenario above.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="entity-cards"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §5  Arrow of Time                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-arrow" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§5</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Arrow of Time</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Sagitta temporis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        Ascent cost vs. descent cost as a function of depth. Near the horizon, escape cost
        diverges relative to infall cost — this asymmetry <em>is</em> time dilation in GCD.
        The ratio grows without bound as ω → 1.
      </p>
      <div class="relative">
        <canvas id="arrow-canvas" style="max-width: 720px; height: 280px; width: 100%;"></canvas>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §6  Tidal Force                                            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-tidal" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§6</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Tidal Force</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Vis discerptionis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The second derivative d²Γ/dω² measures the rate of change of the gravitational field —
        the spaghettification diagnostic. Tidal force is negligible far from the horizon and
        catastrophic near it.
      </p>
      <div class="relative">
        <canvas id="tidal-canvas" style="max-width: 720px; height: 260px; width: 100%;"></canvas>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §7  Gravitational Lensing                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-lensing" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§7</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Gravitational Lensing</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Deflexio luminis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The heterogeneity gap Δ = F − IC determines lensing morphology. Small Δ produces an
        Einstein ring; large Δ yields weak distortion. The deflection angle θ = 4|κ|/(Δ+ε) is
        the GCD analog of Einstein's deflection formula.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="relative">
          <canvas id="lensing-canvas" style="width: 100%; height: 420px;"></canvas>
        </div>
        <div id="lensing-info" class="space-y-3 text-xs"></div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §8  Frame-Dragging                                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-framedrag" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§8</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Frame-Dragging</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Tractio referentiae — Lense-Thirring</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        A spinning black hole drags the local inertial frame. In GCD, ω_drag = a*·Γ(ω)/(1+Γ)²
        grows with both drift and spin. At a* = 0 (Schwarzschild) there is no dragging; as
        a* → 1 the ergosphere swells. Use the spin slider above to see the effect.
      </p>
      <div class="relative">
        <canvas id="framedrag-canvas" style="max-width: 720px; height: 280px; width: 100%;"></canvas>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §9  Penrose Process                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-penrose" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§9</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Penrose Process — Energy Extraction</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Processus Penrose</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The Penrose process extracts rotational energy from a spinning black hole's ergosphere.
        Efficiency η_P = 1 − √((1+√(1−a*²))/2) reaches ≈29.3% at extremal spin (a* → 1).
        Radiative efficiency η_rad from accretion onto the spin-dependent ISCO is also shown,
        peaking at ≈42% for a* → 1.
      </p>
      <div class="relative">
        <canvas id="penrose-canvas" style="max-width: 720px; height: 280px; width: 100%;"></canvas>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §10  Proper Time Dilation & Entropy                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-proper" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§10</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Proper Time Dilation & Entropy</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Moratio temporis proprii</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        The proper-to-coordinate time ratio dτ/dt approaches zero at the horizon — clocks freeze
        for a distant observer. Black hole entropy S_BH = 4πκ² follows the Bekenstein area law:
        deeper wells (larger |κ|) have higher entropy.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="relative">
          <canvas id="timedilation-canvas" style="width: 100%; height: 280px;"></canvas>
        </div>
        <div class="relative">
          <canvas id="entropy-canvas" style="width: 100%; height: 280px;"></canvas>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- §11  Orbital Precession & GW Strain                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div id="sec-gw" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 sm:p-6 mb-6 scroll-mt-24">
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3 mb-1">
        <span class="text-xs font-mono text-kernel-500">§11</span>
        <h2 class="text-base sm:text-lg font-bold text-kernel-200">Orbital Precession & Gravitational Waves</h2>
        <span class="text-[10px] italic text-kernel-500 sm:ml-auto">Praecessio et undae gravitatis</span>
      </div>
      <p class="text-sm text-kernel-400 mb-4 max-w-2xl leading-relaxed">
        Orbital precession δφ = 6πΓ(ω)/(1+Γ)² grows super-linearly near the horizon.
        Gravitational wave strain h = Γ²·C/d radiates the curvature channel as quadrupole waves —
        only asymmetric systems (C &gt; 0) emit. The observer distance slider above scales h inversely.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="relative">
          <canvas id="precession-canvas" style="width: 100%; height: 280px;"></canvas>
        </div>
        <div class="relative">
          <canvas id="gwstrain-canvas" style="width: 100%; height: 280px;"></canvas>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { computeKernel, classifyRegime, gammaOmega } from '../lib/kernel';
  import { EPSILON, P_EXPONENT, ALPHA, OMEGA_TRAP, C_TRAP } from '../lib/constants';
  import {
    budgetSurfaceHeight, dGamma, d2Gamma, wellDepth,
    deflectionAngle, classifyLensing, descentCost, ascentCost,
    arrowAsymmetry, BLACK_HOLE_ENTITIES,
    hawkingTemperature, gravitationalRedshift, escapeVelocity,
    frameDragging, penroseEfficiency, bhEntropy,
    orbitalPrecession, gwStrain, surfaceGravity,
    properTimeFactor, radiativeEfficiency,
    type SpacetimeEntity,
  } from '../lib/spacetime';
  import { initBlackHole3D } from '../lib/webgl-blackhole';

  /* --- Helpers ----------------------------------------------------- */

  function fmtV(v: number): string {
    if (!isFinite(v)) return 'inf';
    const a = Math.abs(v);
    if (a >= 10000) return v.toExponential(2);
    if (a >= 100) return v.toFixed(1);
    if (a < 0.001 && a > 0) return v.toExponential(2);
    return v.toFixed(4);
  }

  function regimeColor(regime: string): string {
    if (regime === 'STABLE') return '#34d399';
    if (regime === 'WATCH') return '#fbbf24';
    return '#ef4444';
  }

  function regimeBg(regime: string): string {
    if (regime === 'STABLE') return 'bg-green-900/40 border-green-700 text-green-400';
    if (regime === 'WATCH') return 'bg-amber-900/40 border-amber-700 text-amber-400';
    return 'bg-red-900/40 border-red-700 text-red-400';
  }

  function setupCanvas(id: string, cssW: number, cssH: number): [HTMLCanvasElement, CanvasRenderingContext2D, number] {
    const canvas = document.getElementById(id) as HTMLCanvasElement;
    const container = canvas.parentElement!;
    const w = Math.min(container.clientWidth, cssW);
    const dpr = window.devicePixelRatio || 1;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(cssH * dpr);
    canvas.style.width = w + 'px';
    canvas.style.height = cssH + 'px';
    const ctx = canvas.getContext('2d')!;
    ctx.scale(dpr, dpr);
    return [canvas, ctx, w];
  }

  /* --- Global State ------------------------------------------------ */

  interface ScenarioPreset {
    id: string;
    spin: number;
    distance: number;
    description: string;
    highlight?: string; // entity name to highlight
  }

  const SCENARIOS: Record<string, ScenarioPreset> = {
    stellar:     { id: 'stellar',     spin: 0.100, distance: 1.0, description: 'A stellar-mass black hole (3–20 M☉) formed from core-collapse supernova. Low spin, modest lensing, pronounced regime boundaries.' },
    supermassive:{ id: 'supermassive',spin: 0.500, distance: 5.0, description: 'Sgr A* — the supermassive black hole at the Milky Way center (4.15×10⁶ M☉). Moderate spin, immense well depth, strong frame-dragging.' },
    kerr:        { id: 'kerr',        spin: 0.700, distance: 1.0, description: 'A rapidly rotating Kerr black hole (a* ≈ 0.998 theoretical max). Frame-dragging dominates; the ergosphere expands, enabling the Penrose process.' },
    binary:      { id: 'binary',      spin: 0.680, distance: 0.4, description: 'Binary merger inspiral (LIGO/Virgo). High curvature C produces strong gravitational wave strain. Spin is the final remnant estimate.' },
    primordial:  { id: 'primordial',  spin: 0.010, distance: 0.1, description: 'Primordial micro black hole (≈10¹⁵ g). Tiny well depth, high Hawking temperature, rapid evaporation. Near the Stable–Watch boundary.' },
    charged:     { id: 'charged',     spin: 0.300, distance: 1.0, description: 'Reissner-Nordström (charged, non-rotating). Two horizons when Q < M. Charge channel modifies the trace vector structure.' },
    custom:      { id: 'custom',      spin: 0.700, distance: 1.0, description: 'Build your own black hole by editing the 8-channel trace vector below. All kernel invariants and charts update live.' },
  };

  const CHANNEL_NAMES = ['mass_log', 'spin_norm', 'charge_norm', 'angular_mom', 'radial_pos', 'temp_norm', 'entropy_norm', 'curvature_norm'];

  let currentSpin = 0.700;
  let currentDistance = 1.0;
  let currentScenario = 'kerr';
  let customTrace = [0.65, 0.70, 0.10, 0.55, 0.40, 0.30, 0.50, 0.45];

  /* --- Entity Kernel Data ---------------------------------------- */

  const entityData = BLACK_HOLE_ENTITIES.map(e => {
    const kr = computeKernel(e.c, e.w);
    const rg = classifyRegime(kr);
    return { entity: e, kernel: kr, regime: rg.regime, isCritical: rg.isCritical };
  });

  /* --- Scenario Controls ----------------------------------------- */

  function initControls() {
    const scenarioSelect = document.getElementById('scenario-select') as HTMLSelectElement;
    const spinSlider = document.getElementById('spin-slider') as HTMLInputElement;
    const spinVal = document.getElementById('spin-val')!;
    const distSlider = document.getElementById('dist-slider') as HTMLInputElement;
    const distVal = document.getElementById('dist-val')!;
    const descEl = document.getElementById('scenario-desc')!;
    const builderEl = document.getElementById('custom-builder')!;
    const channelsEl = document.getElementById('custom-channels')!;

    function updateReadout() {
      // Compute kernel for first entity as representative
      const e0 = entityData[0];
      const kr = e0.kernel;
      document.getElementById('ro-F')!.textContent = `F=${kr.F.toFixed(3)}`;
      document.getElementById('ro-omega')!.textContent = `ω=${kr.omega.toFixed(3)}`;
      document.getElementById('ro-IC')!.textContent = `IC=${kr.IC.toFixed(3)}`;
      document.getElementById('ro-delta')!.textContent = `Δ=${kr.delta.toFixed(3)}`;
    }

    function applyScenario() {
      const s = SCENARIOS[currentScenario];
      currentSpin = s.spin;
      currentDistance = s.distance;
      spinSlider.value = String(currentSpin);
      spinVal.textContent = currentSpin.toFixed(3);
      distSlider.value = String(currentDistance);
      distVal.textContent = currentDistance.toFixed(1);
      descEl.textContent = s.description;
      builderEl.classList.toggle('hidden', currentScenario !== 'custom');
      updateReadout();
      renderAll();
    }

    function buildCustomChannels() {
      channelsEl.innerHTML = CHANNEL_NAMES.map((name, i) => `
        <div>
          <label class="text-[10px] text-kernel-400 block mb-0.5">${name}</label>
          <div class="flex items-center gap-1.5">
            <input type="range" min="0" max="1" step="0.01" value="${customTrace[i]}"
                   class="flex-1 accent-blue-500 custom-ch" data-idx="${i}" />
            <span class="text-[10px] font-mono text-kernel-300 w-8 text-right custom-ch-val">${customTrace[i].toFixed(2)}</span>
          </div>
        </div>
      `).join('');

      channelsEl.querySelectorAll('.custom-ch').forEach(el => {
        (el as HTMLInputElement).addEventListener('input', () => {
          const idx = parseInt((el as HTMLInputElement).dataset.idx!);
          customTrace[idx] = parseFloat((el as HTMLInputElement).value);
          const valSpan = el.parentElement!.querySelector('.custom-ch-val')!;
          valSpan.textContent = customTrace[idx].toFixed(2);
          updateReadout();
          renderAll();
        });
      });
    }

    scenarioSelect.addEventListener('change', () => {
      currentScenario = scenarioSelect.value;
      applyScenario();
    });

    spinSlider.addEventListener('input', () => {
      currentSpin = parseFloat(spinSlider.value);
      spinVal.textContent = currentSpin.toFixed(3);
      renderAll();
    });

    distSlider.addEventListener('input', () => {
      currentDistance = parseFloat(distSlider.value);
      distVal.textContent = currentDistance.toFixed(1);
      renderAll();
    });

    buildCustomChannels();
    applyScenario();
  }

  /* --- 1. Infall Simulator --------------------------------------- */

  function renderInfall() {
    const slider = document.getElementById('infall-omega') as HTMLInputElement;
    const omega = parseFloat(slider.value);
    const F = 1 - omega;
    const gamma = gammaOmega(omega);
    const dg = dGamma(omega);
    const d2g = d2Gamma(omega);
    const wd = wellDepth(Math.log(Math.max(F, EPSILON)));
    const escapeRatio = arrowAsymmetry(0.01, omega);

    // Regime
    let regime: string;
    if (omega < 0.038) regime = 'STABLE';
    else if (omega < 0.30) regime = 'WATCH';
    else regime = 'COLLAPSE';

    document.getElementById('infall-omega-val')!.textContent = omega.toFixed(3);
    const regimeEl = document.getElementById('infall-regime')!;
    regimeEl.textContent = regime + (omega > 0.95 ? ' — NEAR HORIZON' : '');
    regimeEl.style.color = regimeColor(regime);

    // Metrics
    const metricsHtml = [
      { label: 'Γ(ω) — Drift Cost', value: fmtV(gamma), color: '#ef4444' },
      { label: 'dΓ/dω — Gravity', value: fmtV(dg), color: '#f97316' },
      { label: 'd²Γ/dω² — Tidal', value: fmtV(d2g), color: '#a855f7' },
      { label: 'Escape Ratio', value: fmtV(escapeRatio) + '×', color: '#60a5fa' },
    ].map(m => `
      <div class="bg-kernel-800 border border-kernel-700 rounded p-3">
        <div class="text-[10px] text-kernel-500 mb-1">${m.label}</div>
        <div class="text-lg font-mono font-bold" style="color:${m.color}">${m.value}</div>
      </div>
    `).join('');
    document.getElementById('infall-metrics')!.innerHTML = metricsHtml;

    // Canvas: Γ(ω) with position marker
    const [canvas, ctx, cssW] = setupCanvas('infall-canvas', 720, 300);
    const cssH = 300;
    const m = { top: 24, right: 20, bottom: 48, left: 64 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    const yMax = 12;
    const mapX = (w: number) => m.left + (w / 1.0) * plotW;
    const mapY = (g: number) => m.top + (1 - Math.min(g, yMax) / yMax) * plotH;

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 10; i++) {
      const x = m.left + (i / 10) * plotW;
      ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
    }
    for (let i = 0; i <= 6; i++) {
      const y = m.top + (i / 6) * plotH;
      ctx.beginPath(); ctx.moveTo(m.left, y); ctx.lineTo(m.left + plotW, y); ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.3)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    // Labels
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '11px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 10; i += 2) {
      ctx.fillText((i / 10).toFixed(1), mapX(i / 10), m.top + plotH + 18);
    }
    ctx.textAlign = 'right';
    for (let i = 0; i <= 6; i++) {
      const val = yMax - (i / 6) * yMax;
      ctx.fillText(val.toFixed(0), m.left - 7, m.top + (i / 6) * plotH + 4);
    }

    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '12px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω (Radial Position → Horizon)', m.left + plotW / 2, cssH - 4);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('Γ(ω)', 0, 0); ctx.restore();

    // Clip
    ctx.save();
    ctx.beginPath(); ctx.rect(m.left, m.top, plotW, plotH); ctx.clip();

    // Regime shading
    // Stable zone
    ctx.fillStyle = 'rgba(52,211,153,0.06)';
    ctx.fillRect(mapX(0), m.top, mapX(0.038) - mapX(0), plotH);
    // Watch zone
    ctx.fillStyle = 'rgba(251,191,36,0.04)';
    ctx.fillRect(mapX(0.038), m.top, mapX(0.30) - mapX(0.038), plotH);
    // Collapse zone
    ctx.fillStyle = 'rgba(239,68,68,0.04)';
    ctx.fillRect(mapX(0.30), m.top, mapX(1.0) - mapX(0.30), plotH);

    // Gradient fill under curve
    const grad = ctx.createLinearGradient(0, m.top, 0, m.top + plotH);
    grad.addColorStop(0, 'rgba(239,68,68,0.15)');
    grad.addColorStop(1, 'rgba(239,68,68,0.01)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(mapX(0), mapY(0));
    for (let i = 0; i < 800; i++) {
      const w = (i / 799) * 0.999;
      ctx.lineTo(mapX(w), mapY(gammaOmega(w)));
    }
    ctx.lineTo(mapX(0.999), mapY(0));
    ctx.closePath(); ctx.fill();

    // Main curve
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2.5;
    ctx.shadowColor = 'rgba(239,68,68,0.5)';
    ctx.shadowBlur = 6;
    ctx.beginPath();
    for (let i = 0; i < 800; i++) {
      const w = (i / 799) * 0.999;
      const g = gammaOmega(w);
      i === 0 ? ctx.moveTo(mapX(w), mapY(g)) : ctx.lineTo(mapX(w), mapY(g));
    }
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Regime boundaries
    ctx.setLineDash([4, 3]);
    ctx.lineWidth = 1;
    ctx.strokeStyle = 'rgba(52,211,153,0.6)';
    ctx.beginPath(); ctx.moveTo(mapX(0.038), m.top); ctx.lineTo(mapX(0.038), m.top + plotH); ctx.stroke();
    ctx.strokeStyle = 'rgba(251,191,36,0.5)';
    ctx.beginPath(); ctx.moveTo(mapX(0.30), m.top); ctx.lineTo(mapX(0.30), m.top + plotH); ctx.stroke();
    ctx.strokeStyle = 'rgba(168,85,247,0.5)';
    ctx.beginPath(); ctx.moveTo(mapX(OMEGA_TRAP), m.top); ctx.lineTo(mapX(OMEGA_TRAP), m.top + plotH); ctx.stroke();
    ctx.setLineDash([]);

    // Labels for regime lines
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'left';
    ctx.fillStyle = 'rgba(52,211,153,0.7)';
    ctx.fillText('Stable', mapX(0.038) + 2, m.top + 12);
    ctx.fillStyle = 'rgba(251,191,36,0.7)';
    ctx.fillText('Watch', mapX(0.30) + 2, m.top + 12);
    ctx.fillStyle = 'rgba(168,85,247,0.7)';
    ctx.fillText('ω_trap', mapX(OMEGA_TRAP) + 2, m.top + 24);

    // Entity dots on curve
    for (const ed of entityData) {
      const ew = ed.kernel.omega;
      const eg = gammaOmega(ew);
      if (ew < 1 && eg < yMax) {
        ctx.beginPath();
        ctx.arc(mapX(ew), mapY(eg), 4, 0, Math.PI * 2);
        ctx.fillStyle = regimeColor(ed.regime);
        ctx.fill();
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    // Your position marker
    const yg = gammaOmega(omega);
    const px = mapX(omega);
    const py = mapY(yg);

    // Vertical line
    ctx.setLineDash([3, 3]);
    ctx.strokeStyle = 'rgba(255,255,255,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(px, m.top); ctx.lineTo(px, m.top + plotH); ctx.stroke();
    ctx.setLineDash([]);

    // Position dot
    ctx.beginPath();
    ctx.arc(px, py, 7, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.shadowColor = 'rgba(255,255,255,0.6)';
    ctx.shadowBlur = 10;
    ctx.fill();
    ctx.shadowBlur = 0;
    ctx.strokeStyle = regimeColor(regime);
    ctx.lineWidth = 2;
    ctx.stroke();

    // Label
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 10px ui-monospace, monospace';
    ctx.textAlign = omega > 0.8 ? 'right' : 'left';
    ctx.fillText(`YOU: ω=${omega.toFixed(3)}  Γ=${fmtV(yg)}`, px + (omega > 0.8 ? -12 : 12), py - 12);

    ctx.restore();

    // Tooltip handling
    const tooltip = document.getElementById('infall-tooltip')!;
    canvas.onmousemove = (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      const dpr = window.devicePixelRatio || 1;
      const cx = mx, cy = my;

      if (cx >= m.left && cx <= m.left + plotW && cy >= m.top && cy <= m.top + plotH) {
        const omH = ((cx - m.left) / plotW) * 1.0;
        const gH = gammaOmega(omH);
        tooltip.className = 'absolute text-xs font-mono bg-kernel-800/95 border border-kernel-600 text-kernel-200 px-2 py-1 rounded shadow-lg pointer-events-none z-10 whitespace-nowrap';
        tooltip.textContent = `ω=${omH.toFixed(3)}  Γ=${fmtV(gH)}  dΓ=${fmtV(dGamma(omH))}`;
        tooltip.style.left = mx + 12 + 'px';
        tooltip.style.top = my - 10 + 'px';
      } else {
        tooltip.className = 'hidden';
      }
    };
    canvas.onmouseleave = () => { tooltip.className = 'hidden'; };
  }

  /* --- 2. Budget Surface Heatmap --------------------------------- */

  function renderSurface() {
    const [canvas, ctx, cssW] = setupCanvas('surface-canvas', 400, 400);
    const cssH = 400;
    const m = { top: 30, right: 10, bottom: 40, left: 50 };
    const plotW = cssW - m.left - m.right;
    const plotH = cssH - m.top - m.bottom;

    ctx.fillStyle = '#06060c';
    ctx.fillRect(0, 0, cssW, cssH);

    // Heatmap
    const res = 400;
    const cellW = plotW / res;
    const cellH = plotH / res;

    // Find max for normalization (capped for visual clarity)
    const maxCost = 5.0;

    for (let i = 0; i < res; i++) {
      for (let j = 0; j < res; j++) {
        const om = (i / res) * 0.999;
        const cv = (j / res) * 1.0;
        const cost = budgetSurfaceHeight(om, cv);
        const t = Math.min(cost / maxCost, 1.0);

        // Color: deep blue -> teal -> yellow -> red
        let r: number, g: number, b: number;
        if (t < 0.25) {
          const s = t / 0.25;
          r = Math.floor(15 + s * 20); g = Math.floor(23 + s * 40); b = Math.floor(42 + s * 55);
        } else if (t < 0.5) {
          const s = (t - 0.25) / 0.25;
          r = Math.floor(35 * (1 - s)); g = Math.floor(63 + s * 32); b = Math.floor(97 * (1 - s) + s * 70);
        } else if (t < 0.75) {
          const s = (t - 0.5) / 0.25;
          r = Math.floor(s * 133 + 10); g = Math.floor(95 * (1 - s) + s * 77); b = Math.floor(70 * (1 - s) + s * 14);
        } else {
          const s = (t - 0.75) / 0.25;
          r = Math.floor(143 + s * 96); g = Math.floor(77 * (1 - s) + s * 29); b = Math.floor(14 * (1 - s));
        }

        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.fillRect(
          m.left + i * cellW,
          m.top + plotH - (j + 1) * cellH,
          cellW + 0.5,
          cellH + 0.5,
        );
      }
    }

    // Axes
    ctx.strokeStyle = 'rgba(255,255,255,0.4)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(m.left, m.top); ctx.lineTo(m.left, m.top + plotH);
    ctx.lineTo(m.left + plotW, m.top + plotH); ctx.stroke();

    // Labels
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 5; i++) {
      ctx.fillText((i / 5).toFixed(1), m.left + (i / 5) * plotW, m.top + plotH + 16);
    }
    ctx.textAlign = 'right';
    for (let i = 0; i <= 5; i++) {
      ctx.fillText((i / 5).toFixed(1), m.left - 5, m.top + plotH - (i / 5) * plotH + 4);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '12px ui-sans-serif, system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('ω (Drift)', m.left + plotW / 2, cssH - 4);
    ctx.save(); ctx.translate(14, m.top + plotH / 2); ctx.rotate(-Math.PI / 2);
    ctx.fillText('C (Curvature)', 0, 0); ctx.restore();

    // Regime boundary lines on surface
    const mapSX = (om: number) => m.left + (om / 1.0) * plotW;
    ctx.setLineDash([4, 3]);
    ctx.lineWidth = 1;
    ctx.strokeStyle = 'rgba(52,211,153,0.5)';
    ctx.beginPath(); ctx.moveTo(mapSX(0.038), m.top); ctx.lineTo(mapSX(0.038), m.top + plotH); ctx.stroke();
    ctx.strokeStyle = 'rgba(251,191,36,0.4)';
    ctx.beginPath(); ctx.moveTo(mapSX(0.30), m.top); ctx.lineTo(mapSX(0.30), m.top + plotH); ctx.stroke();
    ctx.setLineDash([]);

    // Entity markers
    const mapSY = (cv: number) => m.top + plotH - (cv / 1.0) * plotH;

    const colors = ['#ef4444', '#f97316', '#a855f7', '#34d399', '#60a5fa', '#ec4899'];
    const legendEl = document.getElementById('entity-legend')!;
    let legendHtml = '';

    entityData.forEach((ed, i) => {
      const ex = mapSX(ed.kernel.omega);
      const ey = mapSY(ed.kernel.C);
      const color = colors[i % colors.length];

      // Dot with border
      ctx.beginPath();
      ctx.arc(ex, ey, 5, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
      ctx.strokeStyle = '#000';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Label
      ctx.fillStyle = color;
      ctx.font = 'bold 9px ui-monospace, monospace';
      ctx.textAlign = 'left';
      ctx.fillText(ed.entity.symbol, ex + 8, ey + 3);

      legendHtml += `
        <div class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-full flex-shrink-0" style="background:${color}"></span>
          <span class="text-kernel-300 font-mono">${ed.entity.symbol}</span>
          <span class="text-kernel-500">${ed.entity.name}</span>
          <span class="text-kernel-600 ml-auto">${ed.regime}</span>
        </div>`;
    });
    legendEl.innerHTML = legendHtml;
  }

