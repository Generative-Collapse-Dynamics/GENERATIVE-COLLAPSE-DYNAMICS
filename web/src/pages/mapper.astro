---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhysicalMapper from '../components/PhysicalMapper.astro';
---

<BaseLayout title="Physical Signature Mapper — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Physical Signature Mapper</h1>
      <p class="text-kernel-400">
        Map kernel invariants to real-world physical entities. Identify known matter by its
        kernel signature, interpret what each invariant means physically, predict properties
        of unknown compositions, and explore all reference entities across scales.
      </p>
    </div>
    <PhysicalMapper />
  </div>
</BaseLayout>
