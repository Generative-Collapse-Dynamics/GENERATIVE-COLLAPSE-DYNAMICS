---
import BaseLayout from '../layouts/BaseLayout.astro';
import TauRStar from '../components/TauRStar.astro';
---

<BaseLayout title="τ_R* Diagnostic — GCD">
  <div class="max-w-5xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">τ_R* Thermodynamic Diagnostic</h1>
      <p class="text-kernel-400">
        τ_R* measures how favorable return conditions are from any point in the ω–C plane.
        Higher values indicate easier return from collapse. Includes the drift cost curve Γ(ω).
      </p>
    </div>
    <TauRStar />
  </div>
</BaseLayout>
