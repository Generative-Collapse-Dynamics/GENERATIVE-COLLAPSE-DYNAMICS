---
/**
 * Physical Signature Mapper — Interactive entity identification
 *
 * Four modes:
 *   1. Identify — input kernel values or trace, find nearest known entities
 *   2. Interpret — explain what each invariant value means physically
 *   3. Predict — when no close match, predict scale/structure/composition
 *   4. Atlas — visual map of all reference entities across scales
 */
---

<div id="physical-mapper" class="space-y-4">
  <!-- Tab navigation -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-2">
    <div class="flex flex-wrap gap-1" role="tablist">
      <button class="pm-tab px-3 py-1.5 rounded text-sm transition" data-tab="identify" role="tab" aria-selected="true">
        🔍 Identify
      </button>
      <button class="pm-tab px-3 py-1.5 rounded text-sm transition" data-tab="interpret" role="tab" aria-selected="false">
        📖 Interpret
      </button>
      <button class="pm-tab px-3 py-1.5 rounded text-sm transition" data-tab="predict" role="tab" aria-selected="false">
        🧪 Predict Unknown
      </button>
      <button class="pm-tab px-3 py-1.5 rounded text-sm transition" data-tab="atlas" role="tab" aria-selected="false">
        🗺️ Entity Atlas
      </button>
    </div>
  </div>

  <!-- ═══════════ TAB 1: Identify ═══════════ -->
  <div id="pm-identify" class="pm-panel space-y-4">
    <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
      <h3 class="text-lg font-semibold text-kernel-100 mb-3">Signature Identification</h3>
      <p class="text-sm text-kernel-400 mb-4">
        Enter kernel invariant values or a trace vector to find the closest known physical entities.
      </p>

      <!-- Input mode toggle -->
      <div class="flex gap-2 mb-4">
        <button id="pm-mode-kernel" class="pm-mode-btn px-3 py-1 rounded text-sm bg-kernel-600 text-kernel-100">
          Kernel Values (F, ω, IC…)
        </button>
        <button id="pm-mode-trace" class="pm-mode-btn px-3 py-1 rounded text-sm bg-kernel-800 text-kernel-400">
          Trace Vector (8 channels)
        </button>
        <button id="pm-mode-preset" class="pm-mode-btn px-3 py-1 rounded text-sm bg-kernel-800 text-kernel-400">
          Reference Entity
        </button>
      </div>

      <!-- Kernel input -->
      <div id="pm-kernel-input" class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
        <div>
          <label class="text-xs text-kernel-500">F (Fidelity)</label>
          <input type="number" id="pm-F" value="0.750" step="0.01" min="0" max="1"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100">
        </div>
        <div>
          <label class="text-xs text-kernel-500">ω (Drift)</label>
          <input type="number" id="pm-omega" value="0.250" step="0.01" min="0" max="1"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100" disabled>
        </div>
        <div>
          <label class="text-xs text-kernel-500">IC (Integrity)</label>
          <input type="number" id="pm-IC" value="0.500" step="0.01" min="0" max="1"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100">
        </div>
        <div>
          <label class="text-xs text-kernel-500">Δ (Gap = F − IC)</label>
          <input type="number" id="pm-delta" value="0.250" step="0.01"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100" disabled>
        </div>
        <div>
          <label class="text-xs text-kernel-500">S (Entropy)</label>
          <input type="number" id="pm-S" value="0.550" step="0.01" min="0" max="2"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100">
        </div>
        <div>
          <label class="text-xs text-kernel-500">C (Curvature)</label>
          <input type="number" id="pm-C" value="0.150" step="0.01" min="0" max="1"
            class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100">
        </div>
      </div>

      <!-- Trace input (hidden by default) -->
      <div id="pm-trace-input" class="hidden mb-4">
        <label class="text-xs text-kernel-500 mb-1 block">8-Channel Trace Vector (comma-separated)</label>
        <div class="flex gap-2">
          <input type="text" id="pm-trace-values" value="0.77, 0.82, 0.71, 0.88, 0.78, 0.76, 0.79, 0.65"
            class="flex-1 bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100 font-mono">
          <button id="pm-compute-trace" class="px-3 py-1 bg-kernel-600 hover:bg-kernel-500 rounded text-sm text-kernel-100 transition">
            Compute
          </button>
        </div>
        <p class="text-xs text-kernel-500 mt-1">Each value in [0, 1]. Equal weights assumed.</p>
      </div>

      <!-- Preset selector (hidden by default) -->
      <div id="pm-preset-input" class="hidden mb-4">
        <label class="text-xs text-kernel-500 mb-1 block">Select a Reference Entity</label>
        <select id="pm-entity-select"
          class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-100">
        </select>
      </div>

      <!-- Scale filter -->
      <div class="flex gap-2 items-center mb-4">
        <label class="text-xs text-kernel-500">Scale filter:</label>
        <select id="pm-scale-filter"
          class="bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-xs text-kernel-100">
          <option value="all">All scales</option>
          <option value="subatomic">Subatomic</option>
          <option value="hadronic">Hadronic</option>
          <option value="nuclear">Nuclear</option>
          <option value="atomic">Atomic</option>
          <option value="molecular">Molecular</option>
          <option value="bulk">Bulk Material</option>
          <option value="astronomical">Astronomical</option>
          <option value="abstract">Abstract / Emergent</option>
        </select>
        <button id="pm-identify-btn" class="px-4 py-1.5 bg-emerald-600 hover:bg-emerald-500 rounded text-sm font-medium text-white transition">
          Identify ↵
        </button>
      </div>
    </div>

    <!-- Results -->
    <div id="pm-identify-results" class="space-y-3"></div>
  </div>

  <!-- ═══════════ TAB 2: Interpret ═══════════ -->
  <div id="pm-interpret" class="pm-panel hidden space-y-4">
    <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
      <h3 class="text-lg font-semibold text-kernel-100 mb-3">Physical Interpretation</h3>
      <p class="text-sm text-kernel-400 mb-4">
        Click a kernel invariant to see its physical meaning across different scales.
        Each number has a physical consequence.
      </p>

      <!-- Invariant quick-buttons -->
      <div class="flex flex-wrap gap-2 mb-4">
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="F">
          F — Fidelity
        </button>
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="omega">
          ω — Drift
        </button>
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="IC">
          IC — Integrity
        </button>
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="delta">
          Δ — Heterogeneity Gap
        </button>
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="S">
          S — Entropy
        </button>
        <button class="pm-inv-btn px-3 py-1.5 rounded text-sm bg-kernel-700 hover:bg-kernel-600 text-kernel-100 transition" data-inv="C">
          C — Curvature
        </button>
      </div>
    </div>

    <!-- Interpretation panel -->
    <div id="pm-interpret-result" class="space-y-3"></div>
  </div>

  <!-- ═══════════ TAB 3: Predict Unknown ═══════════ -->
  <div id="pm-predict" class="pm-panel hidden space-y-4">
    <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
      <h3 class="text-lg font-semibold text-kernel-100 mb-3">Predict Unknown Composition</h3>
      <p class="text-sm text-kernel-400 mb-4">
        Input a trace vector from an unknown or hypothetical system. The mapper will predict
        its physical scale, structure, composition, and stability based on kernel similarity
        to known entities. Novel signatures (high distance from all references) may indicate
        unknown matter compositions.
      </p>

      <div class="grid grid-cols-4 gap-2 mb-4" id="pm-predict-channels">
        <!-- 8 channel sliders generated by JS -->
      </div>

      <div class="flex gap-2 items-center">
        <button id="pm-predict-random" class="px-3 py-1 bg-kernel-700 hover:bg-kernel-600 rounded text-sm text-kernel-400 transition">
          Random Trace
        </button>
        <button id="pm-predict-novel" class="px-3 py-1 bg-kernel-700 hover:bg-kernel-600 rounded text-sm text-kernel-400 transition">
          Novel Region
        </button>
        <button id="pm-predict-btn" class="px-4 py-1.5 bg-amber-600 hover:bg-amber-500 rounded text-sm font-medium text-white transition">
          Predict Properties ↵
        </button>
      </div>
    </div>

    <!-- Prediction results -->
    <div id="pm-predict-results" class="space-y-3"></div>
  </div>

  <!-- ═══════════ TAB 4: Entity Atlas ═══════════ -->
  <div id="pm-atlas" class="pm-panel hidden space-y-4">
    <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
      <h3 class="text-lg font-semibold text-kernel-100 mb-3">Entity Atlas</h3>
      <p class="text-sm text-kernel-400 mb-2">
        All reference entities plotted in kernel space. Hover for details. Click to load into Identify tab.
      </p>

      <!-- Axis selectors -->
      <div class="flex gap-4 items-center mb-2">
        <div>
          <label class="text-xs text-kernel-500">X axis:</label>
          <select id="pm-atlas-x" class="bg-kernel-800 border border-kernel-600 rounded px-1 py-0.5 text-xs text-kernel-100">
            <option value="F" selected>F (Fidelity)</option>
            <option value="omega">ω (Drift)</option>
            <option value="IC">IC (Integrity)</option>
            <option value="delta">Δ (Gap)</option>
            <option value="S">S (Entropy)</option>
            <option value="C">C (Curvature)</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-kernel-500">Y axis:</label>
          <select id="pm-atlas-y" class="bg-kernel-800 border border-kernel-600 rounded px-1 py-0.5 text-xs text-kernel-100">
            <option value="F">F (Fidelity)</option>
            <option value="omega">ω (Drift)</option>
            <option value="IC" selected>IC (Integrity)</option>
            <option value="delta">Δ (Gap)</option>
            <option value="S">S (Entropy)</option>
            <option value="C">C (Curvature)</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-kernel-500">Color by:</label>
          <select id="pm-atlas-color" class="bg-kernel-800 border border-kernel-600 rounded px-1 py-0.5 text-xs text-kernel-100">
            <option value="scale" selected>Scale</option>
            <option value="regime">Regime</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Atlas canvas -->
    <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
      <canvas id="pm-atlas-canvas" width="800" height="500" class="w-full rounded border border-kernel-700" style="max-height: 500px;"></canvas>
      <div id="pm-atlas-tooltip" class="hidden absolute bg-kernel-800 border border-kernel-600 rounded px-3 py-2 text-xs text-kernel-200 shadow-lg z-10 max-w-sm pointer-events-none"></div>
    </div>

    <!-- Entity list -->
    <div id="pm-atlas-list" class="space-y-2"></div>
  </div>
</div>

<style>
  .pm-tab[aria-selected="true"] {
    background-color: rgb(var(--color-kernel-600));
    color: rgb(var(--color-kernel-100));
    font-weight: 500;
  }
  .pm-tab[aria-selected="false"] {
    background-color: transparent;
    color: rgb(var(--color-kernel-400));
  }
  .pm-tab:hover {
    background-color: rgb(var(--color-kernel-700));
    color: rgb(var(--color-kernel-100));
  }
  .pm-inv-btn.active {
    background-color: rgb(var(--color-kernel-500));
    font-weight: 600;
  }
  .pm-mode-btn.active {
    background-color: rgb(var(--color-kernel-600));
    color: rgb(var(--color-kernel-100));
  }
</style>

<script>
  import { computeKernel, classifyRegime, type KernelResult } from '../lib/kernel';
  import {
    PHYSICAL_ENTITIES,
    SCALE_INFO,
    findNearestEntities,
    classifyScale,
    interpretKernel,
    predictProperties,
    kernelDistance,
    type PhysicalEntity,
    type PhysicalScale,
    type SignatureMatch,
  } from '../lib/physical-signatures';

  /* ─── Globals ─────────────────────────────────────────────── */

  let currentMode = 'kernel';
  let currentTab = 'identify';

  /* ─── Helper: get entity kernel ───────────────────────────── */

  function entityKernel(e: PhysicalEntity): KernelResult {
    return computeKernel(e.c, e.w);
  }

  /* ─── Tab Switching ───────────────────────────────────────── */

  document.querySelectorAll('.pm-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab!;
      currentTab = target;
      document.querySelectorAll('.pm-tab').forEach(t => t.setAttribute('aria-selected', 'false'));
      tab.setAttribute('aria-selected', 'true');
      document.querySelectorAll('.pm-panel').forEach(p => (p as HTMLElement).classList.add('hidden'));
      document.getElementById(`pm-${target}`)!.classList.remove('hidden');
      if (target === 'atlas') renderAtlas();
    });
  });

  /* ─── Input Mode Toggle ───────────────────────────────────── */

  const modeKernel = document.getElementById('pm-mode-kernel')!;
  const modeTrace = document.getElementById('pm-mode-trace')!;
  const modePreset = document.getElementById('pm-mode-preset')!;

  function setMode(mode: string) {
    currentMode = mode;
    [modeKernel, modeTrace, modePreset].forEach(b => {
      b.classList.remove('bg-kernel-600', 'text-kernel-100');
      b.classList.add('bg-kernel-800', 'text-kernel-400');
    });
    const active = mode === 'kernel' ? modeKernel : mode === 'trace' ? modeTrace : modePreset;
    active.classList.remove('bg-kernel-800', 'text-kernel-400');
    active.classList.add('bg-kernel-600', 'text-kernel-100');

    document.getElementById('pm-kernel-input')!.classList.toggle('hidden', mode !== 'kernel');
    document.getElementById('pm-trace-input')!.classList.toggle('hidden', mode !== 'trace');
    document.getElementById('pm-preset-input')!.classList.toggle('hidden', mode !== 'preset');
  }

  modeKernel.addEventListener('click', () => setMode('kernel'));
  modeTrace.addEventListener('click', () => setMode('trace'));
  modePreset.addEventListener('click', () => setMode('preset'));

  /* ─── Populate entity dropdown ────────────────────────────── */

  const entitySelect = document.getElementById('pm-entity-select') as HTMLSelectElement;
  const groupedEntities: Record<string, PhysicalEntity[]> = {};
  PHYSICAL_ENTITIES.forEach(e => {
    if (!groupedEntities[e.scale]) groupedEntities[e.scale] = [];
    groupedEntities[e.scale].push(e);
  });
  for (const [scale, entities] of Object.entries(groupedEntities)) {
    const group = document.createElement('optgroup');
    group.label = SCALE_INFO[scale as PhysicalScale]?.label ?? scale;
    entities.forEach(e => {
      const opt = document.createElement('option');
      opt.value = e.name;
      opt.textContent = `${e.symbol ? e.symbol + ' ' : ''}${e.name}`;
      group.appendChild(opt);
    });
    entitySelect.appendChild(group);
  }

  /* ─── F/omega coupling ────────────────────────────────────── */

  const inputF = document.getElementById('pm-F') as HTMLInputElement;
  const inputOmega = document.getElementById('pm-omega') as HTMLInputElement;
  const inputIC = document.getElementById('pm-IC') as HTMLInputElement;
  const inputDelta = document.getElementById('pm-delta') as HTMLInputElement;

  inputF.addEventListener('input', () => {
    const f = parseFloat(inputF.value) || 0;
    inputOmega.value = (1 - f).toFixed(3);
    const ic = parseFloat(inputIC.value) || 0;
    inputDelta.value = Math.max(0, f - ic).toFixed(3);
  });
  inputIC.addEventListener('input', () => {
    const f = parseFloat(inputF.value) || 0;
    const ic = parseFloat(inputIC.value) || 0;
    inputDelta.value = Math.max(0, f - ic).toFixed(3);
  });

  /* ─── Compute trace → kernel ──────────────────────────────── */

  document.getElementById('pm-compute-trace')!.addEventListener('click', () => {
    const raw = (document.getElementById('pm-trace-values') as HTMLInputElement).value;
    const vals = raw.split(',').map(s => parseFloat(s.trim())).filter(v => !isNaN(v));
    if (vals.length < 2) return;
    const w = Array(vals.length).fill(1 / vals.length);
    const kr = computeKernel(vals, w);
    inputF.value = kr.F.toFixed(4);
    inputOmega.value = kr.omega.toFixed(4);
    inputIC.value = kr.IC.toFixed(4);
    inputDelta.value = kr.delta.toFixed(4);
    (document.getElementById('pm-S') as HTMLInputElement).value = kr.S.toFixed(4);
    (document.getElementById('pm-C') as HTMLInputElement).value = kr.C.toFixed(4);
    setMode('kernel');
  });

  /* ─── Entity preset → kernel ──────────────────────────────── */

  entitySelect.addEventListener('change', () => {
    const name = entitySelect.value;
    const entity = PHYSICAL_ENTITIES.find(e => e.name === name);
    if (!entity) return;
    const kr = entityKernel(entity);
    inputF.value = kr.F.toFixed(4);
    inputOmega.value = kr.omega.toFixed(4);
    inputIC.value = kr.IC.toFixed(4);
    inputDelta.value = kr.delta.toFixed(4);
    (document.getElementById('pm-S') as HTMLInputElement).value = kr.S.toFixed(4);
    (document.getElementById('pm-C') as HTMLInputElement).value = kr.C.toFixed(4);
  });

  /* ─── Build kernel result from inputs ─────────────────────── */

  function getInputKernel(): KernelResult {
    const F = parseFloat(inputF.value) || 0;
    const omega = 1 - F;
    const IC = Math.min(parseFloat(inputIC.value) || 0, F);
    const S = parseFloat((document.getElementById('pm-S') as HTMLInputElement).value) || 0;
    const C = parseFloat((document.getElementById('pm-C') as HTMLInputElement).value) || 0;
    const kappa = Math.log(Math.max(IC, 1e-15));
    return {
      F, omega, S, C, kappa, IC,
      delta: Math.max(0, F - IC),
      isHomogeneous: C < 0.001,
    };
  }

  /* ─── Scale color mapping ─────────────────────────────────── */

  const SCALE_COLORS: Record<PhysicalScale, string> = {
    subatomic: '#a78bfa', hadronic: '#f87171', nuclear: '#fb923c',
    atomic: '#fbbf24', molecular: '#4ade80', bulk: '#22d3ee',
    astronomical: '#60a5fa', abstract: '#a3e635',
  };

  const REGIME_COLORS: Record<string, string> = {
    STABLE: '#4ade80', WATCH: '#fbbf24', COLLAPSE: '#f87171',
  };

  /* ─── Format match quality badge ──────────────────────────── */

  function qualityBadge(q: string): string {
    const colors: Record<string, string> = {
      exact: 'bg-emerald-500/20 text-emerald-300 border-emerald-500/50',
      close: 'bg-green-500/20 text-green-300 border-green-500/50',
      similar: 'bg-yellow-500/20 text-yellow-300 border-yellow-500/50',
      approximate: 'bg-orange-500/20 text-orange-300 border-orange-500/50',
      distant: 'bg-red-500/20 text-red-300 border-red-500/50',
    };
    return `<span class="text-xs px-1.5 py-0.5 rounded border ${colors[q] || colors.distant}">${q}</span>`;
  }

  /* ═══════════ TAB 1: IDENTIFY ═══════════ */

  document.getElementById('pm-identify-btn')!.addEventListener('click', runIdentify);

  function runIdentify() {
    const target = getInputKernel();
    const filterEl = document.getElementById('pm-scale-filter') as HTMLSelectElement;
    const scaleFilter = filterEl.value === 'all' ? undefined : filterEl.value as PhysicalScale;
    const matches = findNearestEntities(target, 10, scaleFilter);
    const scaleClass = classifyScale(target);
    const regime = classifyRegime(target);

    const container = document.getElementById('pm-identify-results')!;

    // Summary card
    let html = `
      <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-4">
        <div class="flex flex-wrap gap-4 text-sm mb-3">
          <span class="text-kernel-400">Input: F=<span class="text-kernel-100">${target.F.toFixed(3)}</span>
            ω=<span class="text-kernel-100">${target.omega.toFixed(3)}</span>
            IC=<span class="text-kernel-100">${target.IC.toFixed(3)}</span>
            Δ=<span class="text-kernel-100">${target.delta.toFixed(3)}</span>
            S=<span class="text-kernel-100">${target.S.toFixed(3)}</span>
            C=<span class="text-kernel-100">${target.C.toFixed(3)}</span></span>
        </div>
        <div class="flex flex-wrap gap-3 text-sm">
          <span class="px-2 py-0.5 rounded ${regime.regime === 'STABLE' ? 'bg-emerald-500/20 text-emerald-300' : regime.regime === 'WATCH' ? 'bg-yellow-500/20 text-yellow-300' : 'bg-red-500/20 text-red-300'}">
            ${regime.regime}${regime.isCritical ? ' ⚠ CRITICAL' : ''}
          </span>
          <span class="px-2 py-0.5 rounded bg-kernel-700 ${SCALE_INFO[scaleClass.predictedScale]?.color || 'text-kernel-300'}">
            Predicted scale: ${SCALE_INFO[scaleClass.predictedScale]?.label} (${(scaleClass.confidence * 100).toFixed(0)}%)
          </span>
        </div>
      </div>
    `;

    // Match cards
    html += `<div class="grid gap-2">`;
    matches.forEach((m, i) => {
      const kr = m.kernelResult;
      const sc = SCALE_INFO[m.entity.scale];
      html += `
        <div class="bg-kernel-900/50 border border-kernel-700 rounded-lg p-3 hover:border-kernel-500 transition">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-kernel-500 text-xs font-mono">#${i + 1}</span>
              <span class="font-medium text-kernel-100">${m.entity.symbol ? m.entity.symbol + ' ' : ''}${m.entity.name}</span>
              <span class="text-xs px-1.5 py-0.5 rounded bg-kernel-700 ${sc.color}">${sc.label}</span>
              ${qualityBadge(m.matchQuality)}
            </div>
            <span class="text-xs text-kernel-500 font-mono">d = ${m.distance.toFixed(4)}</span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-1 text-xs text-kernel-400 mb-2">
            <span>Mass: <span class="text-kernel-300">${m.entity.mass}</span></span>
            <span>Size: <span class="text-kernel-300">${m.entity.size}</span></span>
            <span>Category: <span class="text-kernel-300">${m.entity.category}</span></span>
          </div>
          <p class="text-xs text-kernel-500 mb-2">${m.entity.composition}</p>
          <div class="text-xs text-kernel-500">
            <span class="text-kernel-400">Kernel:</span>
            F=${kr.F.toFixed(3)} IC=${kr.IC.toFixed(3)} Δ=${kr.delta.toFixed(3)} S=${kr.S.toFixed(3)} C=${kr.C.toFixed(3)}
          </div>
          <details class="mt-2">
            <summary class="text-xs text-kernel-500 cursor-pointer hover:text-kernel-300">Signature analysis →</summary>
            <p class="text-xs text-kernel-400 mt-1">${m.entity.signatureNote}</p>
            <p class="text-xs text-kernel-500 mt-1"><strong>Key channels:</strong> ${m.entity.keyChannels}</p>
          </details>
        </div>
      `;
