  /* ═══════════ TAB 4: ENTITY ATLAS ═══════════ */

  function renderAtlas() {
    const canvas = document.getElementById('pm-atlas-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const xSel = (document.getElementById('pm-atlas-x') as HTMLSelectElement).value;
    const ySel = (document.getElementById('pm-atlas-y') as HTMLSelectElement).value;
    const colorBy = (document.getElementById('pm-atlas-color') as HTMLSelectElement).value;

    // Compute all kernel results
    const data = PHYSICAL_ENTITIES.map(e => {
      const kr = entityKernel(e);
      const regime = classifyRegime(kr);
      return { entity: e, kr, regime };
    });

    // Get invariant value
    function getValue(kr: KernelResult, field: string): number {
      switch (field) {
        case 'F': return kr.F;
        case 'omega': return kr.omega;
        case 'IC': return kr.IC;
        case 'delta': return kr.delta;
        case 'S': return kr.S;
        case 'C': return kr.C;
        default: return kr.F;
      }
    }

    // Clear
    const W = canvas.width;
    const H = canvas.height;
    const pad = 50;
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0a0a1a';
    ctx.fillRect(0, 0, W, H);

    // Axes
    ctx.strokeStyle = '#334155';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad, pad);
    ctx.lineTo(pad, H - pad);
    ctx.lineTo(W - pad, H - pad);
    ctx.stroke();

    // Labels
    ctx.fillStyle = '#94a3b8';
    ctx.font = '12px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(xSel === 'omega' ? 'ω' : xSel === 'delta' ? 'Δ' : xSel.toUpperCase(), W / 2, H - 10);
    ctx.save();
    ctx.translate(15, H / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText(ySel === 'omega' ? 'ω' : ySel === 'delta' ? 'Δ' : ySel.toUpperCase(), 0, 0);
    ctx.restore();

    // Tick marks
    ctx.textAlign = 'center';
    ctx.font = '10px monospace';
    for (let i = 0; i <= 4; i++) {
      const v = i / 4;
      const x = pad + v * (W - 2 * pad);
      const y = H - pad - v * (H - 2 * pad);
      ctx.fillStyle = '#475569';
      ctx.fillText(v.toFixed(1), x, H - pad + 15);
      ctx.fillText(v.toFixed(1), pad - 20, y + 4);
      // Grid
      ctx.strokeStyle = '#1e293b';
      ctx.beginPath();
      ctx.moveTo(x, pad); ctx.lineTo(x, H - pad);
      ctx.moveTo(pad, y); ctx.lineTo(W - pad, y);
      ctx.stroke();
    }

    // Plot entities
    const plotW = W - 2 * pad;
    const plotH = H - 2 * pad;

    // Store positions for hover detection
    const positions: { x: number; y: number; entity: PhysicalEntity; kr: KernelResult; regime: ReturnType<typeof classifyRegime> }[] = [];

    data.forEach(({ entity, kr, regime }) => {
      const xVal = getValue(kr, xSel);
      const yVal = getValue(kr, ySel);
      const px = pad + xVal * plotW;
      const py = H - pad - yVal * plotH;

      const color = colorBy === 'scale'
        ? SCALE_COLORS[entity.scale]
        : REGIME_COLORS[regime.regime] || '#94a3b8';

      ctx.beginPath();
      ctx.arc(px, py, 6, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.3)';
      ctx.lineWidth = 1;
      ctx.stroke();

      positions.push({ x: px, y: py, entity, kr, regime });
    });

    // Legend
    const legendItems = colorBy === 'scale'
      ? Object.entries(SCALE_COLORS)
      : Object.entries(REGIME_COLORS);

    ctx.font = '10px sans-serif';
    ctx.textAlign = 'left';
    legendItems.forEach(([label, color], i) => {
      const lx = W - pad - 100;
      const ly = pad + 15 + i * 18;
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(lx, ly, 5, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = '#94a3b8';
      ctx.fillText(label, lx + 10, ly + 4);
    });

    // Hover tooltip
    const tooltip = document.getElementById('pm-atlas-tooltip')!;
    canvas.onmousemove = (evt) => {
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const mx = (evt.clientX - rect.left) * scaleX;
      const my = (evt.clientY - rect.top) * scaleY;

      let found: typeof positions[0] | null = null;
      let bestDist = 15;  // px threshold
      for (const p of positions) {
        const d = Math.sqrt((mx - p.x) ** 2 + (my - p.y) ** 2);
        if (d < bestDist) { bestDist = d; found = p; }
      }

      if (found) {
        tooltip.classList.remove('hidden');
        tooltip.style.left = (evt.clientX + 15) + 'px';
        tooltip.style.top = (evt.clientY - 10) + 'px';
        tooltip.innerHTML = `
          <strong class="text-kernel-100">${found.entity.symbol ?? ''} ${found.entity.name}</strong>
          <span class="text-kernel-500 ml-2">${found.entity.scale}</span><br>
          <span class="text-kernel-400">${found.entity.category}</span><br>
          <span class="font-mono text-kernel-300">F=${found.kr.F.toFixed(3)} IC=${found.kr.IC.toFixed(3)} Δ=${found.kr.delta.toFixed(3)}</span><br>
          <span class="text-kernel-500">${found.entity.mass}</span>
        `;
      } else {
        tooltip.classList.add('hidden');
      }
    };

    canvas.onmouseleave = () => tooltip.classList.add('hidden');

    // Click to load into Identify
    canvas.onclick = (evt) => {
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const mx = (evt.clientX - rect.left) * scaleX;
      const my = (evt.clientY - rect.top) * scaleY;

      let found: typeof positions[0] | null = null;
      let bestDist = 15;
      for (const p of positions) {
        const d = Math.sqrt((mx - p.x) ** 2 + (my - p.y) ** 2);
        if (d < bestDist) { bestDist = d; found = p; }
      }

      if (found) {
        // Set kernel inputs and switch to identify tab
        inputF.value = found.kr.F.toFixed(4);
        inputOmega.value = found.kr.omega.toFixed(4);
        inputIC.value = found.kr.IC.toFixed(4);
        inputDelta.value = found.kr.delta.toFixed(4);
        (document.getElementById('pm-S') as HTMLInputElement).value = found.kr.S.toFixed(4);
        (document.getElementById('pm-C') as HTMLInputElement).value = found.kr.C.toFixed(4);

        // Switch tab
        const identifyTab = document.querySelector('.pm-tab[data-tab="identify"]')!;
        identifyTab.dispatchEvent(new Event('click'));
        runIdentify();
      }
    };

    // Re-render on axis/color change
    document.getElementById('pm-atlas-x')!.onchange = renderAtlas;
    document.getElementById('pm-atlas-y')!.onchange = renderAtlas;
    document.getElementById('pm-atlas-color')!.onchange = renderAtlas;

    // Entity list by scale
    const listContainer = document.getElementById('pm-atlas-list')!;
    let listHtml = '';
    for (const [scale, info] of Object.entries(SCALE_INFO)) {
      const scaleEntities = data.filter(d => d.entity.scale === scale);
      if (scaleEntities.length === 0) continue;
      listHtml += `
        <details class="bg-kernel-900/50 border border-kernel-700 rounded-lg">
          <summary class="p-3 cursor-pointer hover:bg-kernel-800/50 transition">
            <span class="${info.color} font-medium">${info.label}</span>
            <span class="text-kernel-500 text-xs ml-2">${scaleEntities.length} entities · ${info.sizeRange} · ${info.description}</span>
          </summary>
          <div class="p-3 pt-0 grid gap-1">
            ${scaleEntities.map(({ entity: e, kr, regime }) => `
              <div class="flex items-center justify-between text-xs border-b border-kernel-800 py-1">
                <div class="flex items-center gap-2">
                  <span class="text-kernel-200 font-medium">${e.symbol ?? '—'}</span>
                  <span class="text-kernel-300">${e.name}</span>
                  <span class="text-kernel-500">${e.category}</span>
                </div>
                <div class="flex items-center gap-2 font-mono text-kernel-400">
                  <span>F=${kr.F.toFixed(3)}</span>
                  <span>IC=${kr.IC.toFixed(4)}</span>
                  <span>Δ=${kr.delta.toFixed(3)}</span>
                  <span class="px-1 py-0.5 rounded text-[10px] ${regime.regime === 'STABLE' ? 'bg-emerald-500/20 text-emerald-300' : regime.regime === 'WATCH' ? 'bg-yellow-500/20 text-yellow-300' : 'bg-red-500/20 text-red-300'}">${regime.regime}</span>
                </div>
              </div>
            `).join('')}
          </div>
        </details>
      `;
    }
    listContainer.innerHTML = listHtml;
  }

  /* ─── Initial render ──────────────────────────────────────── */

  // Show default interpretation for F
  renderInterpretation('F');
  document.querySelector('.pm-inv-btn[data-inv="F"]')!.classList.add('active');
</script>
