---
/**
 * Precision Verifier
 * Port of: dashboard/pages_advanced.py render_precision_page()
 *
 * Verifies kernel identities to full floating-point precision.
 * Shows 15-decimal invariants, identity checks, error bounds.
 */
---

<div id="precision-verifier" class="space-y-4">
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
    <h2 class="text-xl font-bold text-kernel-100 mb-2">Precision Verification</h2>
    <p class="text-kernel-400 text-sm">
      Verify the three algebraic identities (F + ω = 1, IC ≤ F, IC = exp(κ))
      to machine precision. All computations run client-side in your browser.
    </p>
  </div>

  <!-- Dimension controls -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Test Configuration</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="text-xs text-kernel-500 block mb-1">Number of Channels</label>
        <input id="prec-n" type="number" min="2" max="64" value="8"
          class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-200 font-mono" />
      </div>
      <div>
        <label class="text-xs text-kernel-500 block mb-1">Random Trials</label>
        <input id="prec-trials" type="number" min="10" max="100000" value="1000"
          class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-200 font-mono" />
      </div>
      <div class="flex items-end">
        <button id="prec-run" class="w-full bg-green-700 hover:bg-green-600 text-white text-sm rounded px-4 py-1.5 transition">
          Run Verification
        </button>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div id="prec-results" class="space-y-4">
    <div class="bg-kernel-900 border border-kernel-600 rounded-lg p-4 text-center text-kernel-500 text-sm">
      Click "Run Verification" to begin.
    </div>
  </div>
</div>

<script>
  import { computeKernel, verifyIdentities, classifyRegime } from '../lib/kernel';

  const runBtn = document.getElementById('prec-run') as HTMLButtonElement;

  runBtn.addEventListener('click', () => {
    const n = parseInt((document.getElementById('prec-n') as HTMLInputElement).value);
    const trials = parseInt((document.getElementById('prec-trials') as HTMLInputElement).value);
    const container = document.getElementById('prec-results')!;

    container.innerHTML = '<div class="bg-kernel-900 border border-kernel-600 rounded-lg p-4 text-center text-yellow-400 text-sm">Running...</div>';

    // Use setTimeout to let the UI update
    setTimeout(() => {
      const startTime = performance.now();

      // Track worst-case errors
      let maxDualityError = 0;
      let maxExpError = 0;
      let boundViolations = 0;
      let totalChecks = 0;

      // Regime distribution
      const regimeCounts: Record<string, number> = {
        'STABLE': 0, 'WATCH': 0, 'COLLAPSE': 0
      };
      let criticalCount = 0;

      // Detailed results for a few samples
      const sampleResults: Array<{
        c: number[];
        F: number;
        omega: number;
        S: number;
        C: number;
        kappa: number;
        IC: number;
        dualErr: number;
        expErr: number;
        icLeF: boolean;
        regime: string;
      }> = [];

      for (let t = 0; t < trials; t++) {
        // Generate random trace vector
        const c = Array.from({length: n}, () => Math.random());
        // Uniform weights
        const w = Array.from({length: n}, () => 1.0 / n);

        const result = computeKernel(c, w);
        const checks = verifyIdentities(result);
        const regime = classifyRegime(result);

        const dualErr = Math.abs(result.F + result.omega - 1);
        const expErr = Math.abs(result.IC - Math.exp(result.kappa));
        const icLeF = result.IC <= result.F + 1e-15;

        maxDualityError = Math.max(maxDualityError, dualErr);
        maxExpError = Math.max(maxExpError, expErr);
        if (!icLeF) boundViolations++;
        totalChecks++;

        regimeCounts[regime.regime]++;
        if (regime.isCritical) criticalCount++;

        if (t < 5) {
          sampleResults.push({
            c: c.slice(0, 4),
            F: result.F,
            omega: result.omega,
            S: result.S,
            C: result.C,
            kappa: result.kappa,
            IC: result.IC,
            dualErr,
            expErr,
            icLeF,
            regime: regime.regime + (regime.isCritical ? ' (CRITICAL)' : ''),
          });
        }
      }

      const elapsed = performance.now() - startTime;

      // Build results HTML
      const verdictColor = boundViolations === 0 && maxDualityError < 1e-10 ? 'text-green-400' : 'text-red-400';
      const verdict = boundViolations === 0 && maxDualityError < 1e-10 ? 'CONFORMANT' : 'NONCONFORMANT';

      container.innerHTML = `
        <!-- Verdict banner -->
        <div class="bg-kernel-900 border ${boundViolations === 0 ? 'border-green-600' : 'border-red-600'} rounded-lg p-4">
          <div class="flex justify-between items-center">
            <div>
              <span class="text-2xl font-bold ${verdictColor}">${verdict}</span>
              <span class="text-kernel-500 text-sm ml-2">${trials.toLocaleString()} trials × ${n} channels in ${elapsed.toFixed(1)}ms</span>
            </div>
            <div class="text-right text-xs text-kernel-500">
              Rate: ${(trials / elapsed * 1000).toFixed(0)} evals/s
            </div>
          </div>
        </div>

        <!-- Identity verification summary -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 text-center">
            <div class="text-xs text-kernel-500 mb-1">Duality: F + ω = 1</div>
            <div class="font-mono text-sm ${maxDualityError < 1e-14 ? 'text-green-400' : 'text-yellow-400'}">
              max |residual| = ${maxDualityError.toExponential(2)}
            </div>
            <div class="text-xs text-kernel-600 mt-1">${maxDualityError < 1e-14 ? 'Exact to machine ε' : 'Within tolerance'}</div>
          </div>

          <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 text-center">
            <div class="text-xs text-kernel-500 mb-1">Integrity Bound: IC ≤ F</div>
            <div class="font-mono text-sm ${boundViolations === 0 ? 'text-green-400' : 'text-red-400'}">
              violations: ${boundViolations} / ${totalChecks}
            </div>
            <div class="text-xs text-kernel-600 mt-1">${boundViolations === 0 ? 'Zero violations' : 'BOUND VIOLATED'}</div>
          </div>

          <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 text-center">
            <div class="text-xs text-kernel-500 mb-1">Log-Integrity: IC = exp(κ)</div>
            <div class="font-mono text-sm ${maxExpError < 1e-12 ? 'text-green-400' : 'text-yellow-400'}">
              max |residual| = ${maxExpError.toExponential(2)}
            </div>
            <div class="text-xs text-kernel-600 mt-1">${maxExpError < 1e-12 ? 'Exact to machine ε' : 'Within tolerance'}</div>
          </div>
        </div>

        <!-- Regime distribution -->
        <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-300 mb-3">Regime Distribution (${trials.toLocaleString()} random traces)</h3>
          <div class="flex gap-1 h-6 rounded overflow-hidden mb-2">
            ${['STABLE', 'WATCH', 'COLLAPSE'].map(r => {
              const pct = (regimeCounts[r] / trials * 100);
              const colors: Record<string, string> = { STABLE: 'bg-green-600', WATCH: 'bg-amber-600', COLLAPSE: 'bg-red-700' };
              return pct > 0 ? `<div class="${colors[r]}" style="width:${pct}%" title="${r}: ${pct.toFixed(1)}%"></div>` : '';
            }).join('')}
          </div>
          <div class="flex justify-between text-xs text-kernel-500">
            <span class="text-green-400">Stable: ${(regimeCounts['STABLE'] / trials * 100).toFixed(1)}%</span>
            <span class="text-amber-400">Watch: ${(regimeCounts['WATCH'] / trials * 100).toFixed(1)}%</span>
            <span class="text-red-400">Collapse: ${(regimeCounts['COLLAPSE'] / trials * 100).toFixed(1)}%</span>
            ${criticalCount > 0 ? `<span class="text-purple-400">Critical: ${(criticalCount / trials * 100).toFixed(1)}%</span>` : ''}
          </div>
        </div>

        <!-- Sample traces -->
        <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-300 mb-3">Sample Traces (first 5)</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-xs font-mono">
              <thead>
                <tr class="text-kernel-500 border-b border-kernel-700">
                  <th class="text-left p-1">c[0..3]</th>
                  <th class="text-right p-1">F</th>
                  <th class="text-right p-1">ω</th>
                  <th class="text-right p-1">S</th>
                  <th class="text-right p-1">C</th>
                  <th class="text-right p-1">κ</th>
                  <th class="text-right p-1">IC</th>
                  <th class="text-right p-1">|F+ω−1|</th>
                  <th class="text-right p-1">IC≤F</th>
                  <th class="text-left p-1">Regime</th>
                </tr>
              </thead>
              <tbody class="text-kernel-300">
                ${sampleResults.map(s => `
                  <tr class="border-b border-kernel-800">
                    <td class="p-1 text-kernel-500">[${s.c.map(v => v.toFixed(3)).join(', ')}…]</td>
                    <td class="text-right p-1">${s.F.toFixed(6)}</td>
                    <td class="text-right p-1">${s.omega.toFixed(6)}</td>
                    <td class="text-right p-1">${s.S.toFixed(6)}</td>
                    <td class="text-right p-1">${s.C.toFixed(6)}</td>
                    <td class="text-right p-1">${s.kappa.toFixed(6)}</td>
                    <td class="text-right p-1">${s.IC.toFixed(6)}</td>
                    <td class="text-right p-1 ${s.dualErr < 1e-14 ? 'text-green-500' : 'text-yellow-500'}">${s.dualErr.toExponential(1)}</td>
                    <td class="text-right p-1 ${s.icLeF ? 'text-green-500' : 'text-red-500'}">${s.icLeF ? '✓' : '✗'}</td>
                    <td class="p-1">${s.regime}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>
      `;
    }, 50);
  });
</script>
