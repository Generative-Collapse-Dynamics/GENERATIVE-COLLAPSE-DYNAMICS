---
/**
 * Rosetta Translator — Complete Five-Word Translation Engine
 *
 * Port of: dashboard/pages_exploration.py render_rosetta_page()
 *
 * Six sections:
 *   1. Five-Word Cards — full operational definitions with formulas
 *   2. Lens Selector + Translation Table — 9 lenses, full vocabulary
 *   3. Lens Detail Panel — expanded description + example on click
 *   4. Live Kernel Scenarios — 5 scenarios with computed kernel
 *   5. Conservation Budget — semantic warranty
 *   6. Discourse Spine — the five-stop grammatical structure
 */
---

<div id="rosetta-translator" class="space-y-6">

  <!-- ────── Header ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <h2 class="text-xl font-bold text-kernel-100 mb-2">Quinque Verba — The Five-Word Vocabulary</h2>
        <p class="text-kernel-400 text-sm max-w-2xl">
          Five words form the minimal prose interface across all 20 domains.
          Each has an operational definition tied to the frozen Contract and reconciled
          in the Integrity Ledger. Authors describe using these five words;
          the ledger, budget, and gates supply the audit.
        </p>
      </div>
      <div class="text-right text-kernel-600 text-xs italic hidden md:block">
        <div>Algebra est cautio, non porta.</div>
        <div class="mt-1 text-kernel-700">The algebra is a warranty, not a gate.</div>
      </div>
    </div>
  </div>

  <!-- ────── Five Word Cards ────── -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3" id="word-cards"></div>

  <!-- ────── Lens Selector ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-bold text-kernel-300">Select Lenses</h3>
      <div class="flex gap-2">
        <button id="lens-all" class="text-xs px-2 py-1 bg-kernel-800 rounded border border-kernel-700 text-kernel-400 hover:text-kernel-200 transition">All</button>
        <button id="lens-none" class="text-xs px-2 py-1 bg-kernel-800 rounded border border-kernel-700 text-kernel-400 hover:text-kernel-200 transition">Clear</button>
      </div>
    </div>
    <div class="flex flex-wrap gap-2" id="lens-buttons"></div>
    <p class="text-xs text-kernel-600 mt-2">Click lens to toggle. Double-click for detail panel.</p>
  </div>

  <!-- ────── Translation Table ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-1">Cross-Lens Translation</h3>
    <p class="text-xs text-kernel-500 mb-3 italic">
      Significatio stabilis manet dum dialectus mutatur — meaning stays stable while dialect changes.
    </p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="rosetta-table">
        <thead>
          <tr class="border-b border-kernel-600 text-kernel-400">
            <th class="text-left p-2 font-medium w-28">Lens</th>
            <th class="text-left p-2 font-medium text-amber-400">Drift <span class="text-kernel-600 font-normal">(ω)</span></th>
            <th class="text-left p-2 font-medium text-green-400">Fidelity <span class="text-kernel-600 font-normal">(F)</span></th>
            <th class="text-left p-2 font-medium text-red-400">Roughness <span class="text-kernel-600 font-normal">(C)</span></th>
            <th class="text-left p-2 font-medium text-blue-400">Return <span class="text-kernel-600 font-normal">(τ_R)</span></th>
          </tr>
        </thead>
        <tbody id="rosetta-body"></tbody>
      </table>
    </div>
    <p class="text-xs text-kernel-600 mt-3 border-t border-kernel-800 pt-3">
      <strong class="text-purple-400">Integrity</strong> (IC) is never a column.
      It is read holistically from the reconciled ledger and stance.
      I ≡ e<sup>κ</sup> provides unitless multiplicative comparability across seams.
    </p>
  </div>

  <!-- ────── Lens Detail Panel ────── -->
  <div id="lens-detail" class="bg-kernel-900 border border-kernel-700 rounded-lg p-4 hidden">
    <div class="flex items-center gap-2 mb-3">
      <h3 class="text-sm font-bold text-kernel-300">Lens Detail</h3>
      <span id="lens-detail-name" class="text-xs bg-kernel-800 px-2 py-0.5 rounded text-kernel-400"></span>
    </div>
    <p id="lens-detail-desc" class="text-sm text-kernel-400 mb-3"></p>
    <div class="bg-kernel-800 rounded p-3 text-xs text-kernel-500">
      <div class="font-medium text-kernel-300 mb-1">Concrete Example</div>
      <p id="lens-detail-example"></p>
    </div>
  </div>

  <!-- ────── Live Kernel Scenarios ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-1">Live Kernel Translation — Scenario Engine</h3>
    <p class="text-xs text-kernel-500 mb-3">
      Select a scenario. The kernel computes invariants client-side and translates the result through all active lenses.
    </p>
    <div class="flex flex-wrap gap-2 mb-4" id="scenario-buttons"></div>

    <div id="scenario-detail" class="hidden space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Left: channel bars -->
        <div>
          <div class="text-xs font-medium text-kernel-400 mb-2">Channel Profile</div>
          <div id="channel-bars" class="space-y-1"></div>
        </div>
        <!-- Right: kernel results -->
        <div>
          <div class="text-xs font-medium text-kernel-400 mb-2">Kernel Invariants</div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2" id="scenario-invariants"></div>
          <div id="scenario-regime" class="mt-2 text-center text-sm font-bold rounded py-1"></div>
          <div id="scenario-identities" class="mt-2 space-y-1"></div>
        </div>
      </div>
      <div>
        <div class="text-xs font-medium text-kernel-400 mb-2">Translation Through Active Lenses</div>
        <div id="scenario-translations" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <!-- ────── Conservation Budget ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-2">Conservation Budget — Semantic Warranty</h3>
    <p class="text-xs text-kernel-500 mb-4">
      The five words ground a conservation law. The algebra is a warranty behind the
      prose — it explains <em>why</em> the ledger must reconcile.
    </p>
    <div class="text-center py-4 bg-kernel-800 rounded-lg">
      <div class="font-mono text-lg text-kernel-200">
        Δκ = R·τ<sub>R</sub> − (D<sub>ω</sub> + D<sub>C</sub>)
      </div>
      <div class="font-mono text-sm text-kernel-400 mt-2">
        I ≡ e<sup>κ</sup> &nbsp;(interpretive density — unitless, multiplicative)
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs text-center mt-4">
      <div class="bg-kernel-800 rounded p-3 border border-kernel-700">
        <div class="text-blue-400 font-bold mb-1">Credit</div>
        <div class="font-mono text-kernel-300">R·τ<sub>R</sub></div>
        <div class="text-kernel-500 mt-1">Return × Re-entry delay</div>
        <div class="text-kernel-600 mt-1 italic">Zero if τ_R = ∞_rec</div>
      </div>
      <div class="bg-kernel-800 rounded p-3 border border-kernel-700">
        <div class="text-amber-400 font-bold mb-1">Debit: Drift</div>
        <div class="font-mono text-kernel-300">D<sub>ω</sub> = Γ(ω) = ω³/(1−ω+ε)</div>
        <div class="text-kernel-500 mt-1">Drift cost closure</div>
        <div class="text-kernel-600 mt-1 italic">Pole at ω=1 guarded by ε=10⁻⁸</div>
      </div>
      <div class="bg-kernel-800 rounded p-3 border border-kernel-700">
        <div class="text-red-400 font-bold mb-1">Debit: Roughness</div>
        <div class="font-mono text-kernel-300">D<sub>C</sub> = α·C</div>
        <div class="text-kernel-500 mt-1">Curvature cost (α = 1.0)</div>
        <div class="text-kernel-600 mt-1 italic">Unit coupling — roughness debits linearly</div>
      </div>
    </div>
    <div class="mt-4 p-3 bg-kernel-800/50 border border-kernel-700 rounded text-xs text-kernel-500">
      <strong class="text-kernel-300">Seam verdict:</strong>
      |residual| ≤ tol_seam (0.005) → <span class="text-green-400">PASS</span>.
      Otherwise → <span class="text-red-400">FAIL</span> (gestus sine receptu).
      <em class="block mt-1 text-kernel-600">Sine receptu, gestus est; cum receptu, sutura est.</em>
    </div>
  </div>

  <!-- ────── Discourse Spine ────── -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-2">Spina Grammatica — The Discourse Spine</h3>
    <p class="text-xs text-kernel-500 mb-4">
      Every claim follows this fixed five-stop spine.
      <em>Spina non negotiabilis est.</em>
    </p>
    <div class="flex flex-col md:flex-row gap-0" id="spine-stops"></div>
  </div>
</div>

<script>
  import {
    ROSETTA_LENSES, FIVE_WORDS, ROSETTA_SCENARIOS,
    DISCOURSE_SPINE,
    type RosettaLens, type FiveWord
  } from '../lib/constants';
  import { computeKernel, classifyRegime, verifyIdentities } from '../lib/kernel';

  // ── State ──
  const selectedLenses = new Set<string>(ROSETTA_LENSES.map(l => l.id));

  // ── Lens Colors ──
  const lensColors: Record<string, { active: string; idle: string }> = {
    epistemology: { active: 'bg-purple-700/50 border-purple-500 text-purple-200', idle: 'hover:bg-purple-900/30' },
    ontology: { active: 'bg-blue-700/50 border-blue-500 text-blue-200', idle: 'hover:bg-blue-900/30' },
    phenomenology: { active: 'bg-teal-700/50 border-teal-500 text-teal-200', idle: 'hover:bg-teal-900/30' },
    history: { active: 'bg-amber-700/50 border-amber-500 text-amber-200', idle: 'hover:bg-amber-900/30' },
    policy: { active: 'bg-red-700/50 border-red-500 text-red-200', idle: 'hover:bg-red-900/30' },
    physics: { active: 'bg-cyan-700/50 border-cyan-500 text-cyan-200', idle: 'hover:bg-cyan-900/30' },
    finance: { active: 'bg-green-700/50 border-green-500 text-green-200', idle: 'hover:bg-green-900/30' },
    security: { active: 'bg-orange-700/50 border-orange-500 text-orange-200', idle: 'hover:bg-orange-900/30' },
    semiotics: { active: 'bg-indigo-700/50 border-indigo-500 text-indigo-200', idle: 'hover:bg-indigo-900/30' },
  };

  const wordColors = ['amber', 'green', 'red', 'blue', 'purple'];

  // ── Word Cards ──
  function renderWordCards() {
    const container = document.getElementById('word-cards')!;
    container.innerHTML = (FIVE_WORDS as unknown as FiveWord[]).map((w, i) => {
      const c = wordColors[i];
      return `
        <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-${c}-400 font-bold">${w.word}</span>
            <span class="font-mono text-kernel-500 text-xs">${w.symbol}</span>
          </div>
          <div class="text-kernel-500 text-xs italic mb-2">${w.latin}</div>
          <div class="font-mono text-kernel-600 text-xs mb-2">${w.formula}</div>
          <div class="text-kernel-400 text-xs mb-2">${w.operational}</div>
          <div class="text-xs text-kernel-600 border-t border-kernel-800 pt-2 mt-2">
            <span class="text-kernel-500 font-medium">Ledger:</span> ${w.ledgerRole}
          </div>
          <div class="text-xs text-kernel-700 mt-1 italic">${w.morphology}</div>
        </div>`;
    }).join('');
  }

  // ── Lens Buttons ──
  function renderButtons() {
    const container = document.getElementById('lens-buttons')!;
    container.innerHTML = ROSETTA_LENSES.map(lens => {
      const active = selectedLenses.has(lens.id);
      const colors = lensColors[lens.id] || { active: 'bg-kernel-700 border-kernel-500 text-kernel-200', idle: '' };
      const cls = active
        ? `${colors.active} ring-1 ring-offset-1 ring-offset-kernel-900`
        : `bg-kernel-800/40 border-kernel-700 text-kernel-500 ${colors.idle}`;
      return `<button data-lens="${lens.id}"
        class="lens-btn px-3 py-1.5 text-xs rounded border transition cursor-pointer ${cls}">
        ${lens.name}</button>`;
    }).join('');

    container.querySelectorAll('.lens-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.lens!;
        if (selectedLenses.has(id)) selectedLenses.delete(id);
        else selectedLenses.add(id);
        renderButtons();
        renderTable();
      });
      btn.addEventListener('dblclick', () => {
        showLensDetail((btn as HTMLElement).dataset.lens!);
      });
    });
  }

  function showLensDetail(id: string) {
    const lens = ROSETTA_LENSES.find(l => l.id === id);
    if (!lens) return;
    const el = document.getElementById('lens-detail')!;
    el.classList.remove('hidden');
    document.getElementById('lens-detail-name')!.textContent = lens.name;
    document.getElementById('lens-detail-desc')!.textContent = lens.description;
    document.getElementById('lens-detail-example')!.textContent = lens.example;
  }

  // ── Translation Table ──
  function renderTable() {
    const tbody = document.getElementById('rosetta-body')!;
    const active = ROSETTA_LENSES.filter(l => selectedLenses.has(l.id));
    if (active.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-kernel-500 p-4">Select at least one lens.</td></tr>';
      return;
    }
    tbody.innerHTML = active.map(lens =>
      `<tr class="border-b border-kernel-800 hover:bg-kernel-800/30 transition cursor-pointer" data-lens-row="${lens.id}">
        <td class="p-2 font-medium text-kernel-300 text-xs whitespace-nowrap">${lens.name}</td>
        <td class="p-2 text-amber-300/80 text-xs">${lens.drift}</td>
        <td class="p-2 text-green-300/80 text-xs">${lens.fidelity}</td>
        <td class="p-2 text-red-300/80 text-xs">${lens.roughness}</td>
        <td class="p-2 text-blue-300/80 text-xs">${lens.return_}</td>
      </tr>`
    ).join('');
    tbody.querySelectorAll('tr[data-lens-row]').forEach(row => {
      row.addEventListener('click', () => showLensDetail((row as HTMLElement).dataset.lensRow!));
    });
  }

  // ── Scenario Engine ──
  function renderScenarios() {
    const container = document.getElementById('scenario-buttons')!;
    container.innerHTML = ROSETTA_SCENARIOS.map((s, i) =>
      `<button data-scenario="${i}"
        class="scenario-btn px-3 py-1.5 text-xs rounded border border-kernel-700 bg-kernel-800 text-kernel-400 hover:bg-kernel-700 hover:text-kernel-200 transition">
        ${s.name}</button>`
    ).join('');

    container.querySelectorAll('.scenario-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.scenario!, 10);
        runScenario(idx);
        container.querySelectorAll('.scenario-btn').forEach(b =>
          b.classList.remove('ring-1', 'ring-kernel-400', 'text-kernel-200'));
        btn.classList.add('ring-1', 'ring-kernel-400', 'text-kernel-200');
      });
    });
  }

  function runScenario(idx: number) {
    const scenario = ROSETTA_SCENARIOS[idx];
    const detail = document.getElementById('scenario-detail')!;
    detail.classList.remove('hidden');

    const result = computeKernel(scenario.channels);
    const regime = classifyRegime(result);
    const identities = verifyIdentities(result);

    // Channel bars
    const barsEl = document.getElementById('channel-bars')!;
    barsEl.innerHTML = scenario.channels.map((c, i) => {
      const pct = (c * 100).toFixed(0);
      const name = scenario.channelNames[i].replace(/_/g, ' ');
      const barColor = c < 0.3 ? 'bg-red-500' : c < 0.7 ? 'bg-amber-500' : 'bg-green-500';
      return `<div class="flex items-center gap-2">
        <span class="text-kernel-500 text-xs w-36 truncate" title="${name}">${name}</span>
        <div class="flex-1 h-3 bg-kernel-800 rounded overflow-hidden">
          <div class="${barColor} h-full rounded" style="width: ${pct}%"></div>
        </div>
        <span class="text-kernel-600 text-xs w-10 text-right">${c.toFixed(2)}</span>
      </div>`;
    }).join('');

    // Invariants
    const invEl = document.getElementById('scenario-invariants')!;
    const metrics = [
      { label: 'F', value: result.F.toFixed(4), color: 'green' },
      { label: 'ω', value: result.omega.toFixed(4), color: 'amber' },
      { label: 'IC', value: result.IC.toFixed(4), color: 'purple' },
      { label: 'Δ', value: result.delta.toFixed(4), color: 'kernel-300' },
      { label: 'S', value: result.S.toFixed(4), color: 'cyan' },
      { label: 'C', value: result.C.toFixed(4), color: 'red' },
    ];
    invEl.innerHTML = metrics.map(m =>
      `<div class="bg-kernel-800 rounded p-2 text-center">
        <div class="text-${m.color}-400 text-xs font-medium">${m.label}</div>
        <div class="text-kernel-200 font-mono text-sm">${m.value}</div>
      </div>`
    ).join('');

    // Regime badge
    const regEl = document.getElementById('scenario-regime')!;
    const rColors: Record<string, string> = {
      STABLE: 'bg-green-900/50 text-green-400 border border-green-700',
      WATCH: 'bg-amber-900/50 text-amber-400 border border-amber-700',
      COLLAPSE: 'bg-red-900/50 text-red-400 border border-red-700',
    };
    regEl.className = `mt-2 text-center text-sm font-bold rounded py-1 ${rColors[regime.regime] || ''}`;
    regEl.textContent = regime.regime + (regime.critical ? ' + CRITICAL' : '');

    // Identity checks
    const idEl = document.getElementById('scenario-identities')!;
    idEl.innerHTML = identities.map(id => {
      const ok = id.passed;
      return `<div class="text-xs ${ok ? 'text-green-400' : 'text-red-400'}">
        ${ok ? '✓' : '✗'} ${id.name}: ${id.value.toExponential(2)}</div>`;
    }).join('');

    // Cross-lens translations for this scenario
    const transEl = document.getElementById('scenario-translations')!;
    const active = ROSETTA_LENSES.filter(l => selectedLenses.has(l.id));
    transEl.innerHTML = active.map(lens =>
      `<div class="bg-kernel-800 rounded p-3 border border-kernel-700">
        <div class="font-medium text-xs text-kernel-300 mb-2">${lens.name}</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs">
          <div><span class="text-amber-500 font-medium">Drift:</span> <span class="text-kernel-400">${lens.drift.split('—')[0].trim()}</span></div>
          <div><span class="text-green-500 font-medium">Fidelity:</span> <span class="text-kernel-400">${lens.fidelity.split('—')[0].trim()}</span></div>
          <div><span class="text-red-500 font-medium">Roughness:</span> <span class="text-kernel-400">${lens.roughness.split('—')[0].trim()}</span></div>
          <div><span class="text-blue-500 font-medium">Return:</span> <span class="text-kernel-400">${lens.return_.split('—')[0].trim()}</span></div>
        </div>
      </div>`
    ).join('');
  }

  // ── Discourse Spine ──
  function renderSpine() {
    const container = document.getElementById('spine-stops')!;
    container.innerHTML = DISCOURSE_SPINE.map((stop, i) => {
      const isLast = i === DISCOURSE_SPINE.length - 1;
      return `
        <div class="flex-1 flex flex-col items-center text-center">
          <div class="bg-kernel-800 border border-kernel-700 rounded-lg p-3 w-full">
            <div class="text-kernel-200 font-bold text-sm">${stop.stop}</div>
            <div class="text-kernel-600 text-xs italic">${stop.latin}</div>
            <div class="text-kernel-500 text-xs mt-1">${stop.verb}</div>
            <div class="text-kernel-400 text-xs mt-2">${stop.role}</div>
          </div>
          ${!isLast ? '<div class="text-kernel-600 text-lg my-1 md:hidden">↓</div>' : ''}
        </div>
        ${!isLast ? '<div class="hidden md:flex items-center text-kernel-600 text-lg px-1">→</div>' : ''}`;
    }).join('');
  }

  // ── Controls ──
  document.getElementById('lens-all')!.addEventListener('click', () => {
    ROSETTA_LENSES.forEach(l => selectedLenses.add(l.id));
    renderButtons();
    renderTable();
  });
  document.getElementById('lens-none')!.addEventListener('click', () => {
    selectedLenses.clear();
    renderButtons();
    renderTable();
  });

  // ── Initialize ──
  renderWordCards();
  renderButtons();
  renderTable();
  renderScenarios();
  renderSpine();
</script>
