---
/**
 * Formula Builder
 * Port of: dashboard/pages_analysis.py render_formula_builder_page()
 *
 * Safe mathematical expression evaluator.
 * Users can build kernel expressions with live evaluation.
 */
---

<div id="formula-builder" class="space-y-4">
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
    <h2 class="text-xl font-bold text-kernel-100 mb-2">Formula Builder</h2>
    <p class="text-kernel-400 text-sm">
      Build and evaluate kernel expressions with live results.
      Variables are bound to slider values. All standard math functions supported.
    </p>
  </div>

  <!-- Variable bindings -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Variable Bindings</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3" id="var-sliders"></div>
  </div>

  <!-- Expression input -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Expression</h3>
    <div class="flex gap-2">
      <input id="formula-input" type="text" value="F + omega"
        class="flex-1 bg-kernel-800 border border-kernel-600 rounded px-3 py-2 text-sm text-kernel-200 font-mono
        focus:border-amber-500 focus:outline-none" placeholder="e.g., F + omega, exp(kappa), IC / F" />
      <button id="formula-eval" class="bg-amber-700 hover:bg-amber-600 text-white text-sm rounded px-4 py-2 transition">
        Evaluate
      </button>
    </div>
    <div id="formula-result" class="mt-3 p-3 bg-kernel-800 rounded font-mono text-sm">
      <span class="text-kernel-500">Result appears here</span>
    </div>
    <div id="formula-error" class="mt-1 text-xs text-red-400 hidden"></div>
  </div>

  <!-- Preset expressions -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Preset Expressions</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2" id="preset-grid"></div>
  </div>

  <!-- Sweep -->
  <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-4">
    <h3 class="text-sm font-bold text-kernel-300 mb-3">Sweep: Evaluate Over Range</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-3">
      <div>
        <label class="text-xs text-kernel-500">Sweep Variable</label>
        <select id="sweep-var" class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-200">
          <option value="F">F (Fidelity)</option>
          <option value="omega">ω (Drift)</option>
          <option value="IC">IC (Integrity)</option>
          <option value="C">C (Curvature)</option>
          <option value="kappa">κ (Log-integrity)</option>
          <option value="S">S (Entropy)</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-kernel-500">From</label>
        <input id="sweep-from" type="number" value="0" step="0.01"
          class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-200 font-mono" />
      </div>
      <div>
        <label class="text-xs text-kernel-500">To</label>
        <input id="sweep-to" type="number" value="1" step="0.01"
          class="w-full bg-kernel-800 border border-kernel-600 rounded px-2 py-1 text-sm text-kernel-200 font-mono" />
      </div>
      <div class="flex items-end">
        <button id="sweep-run" class="w-full bg-blue-700 hover:bg-blue-600 text-white text-sm rounded px-4 py-1.5 transition">
          Sweep
        </button>
      </div>
    </div>
    <canvas id="sweep-canvas" width="600" height="200"
      class="w-full max-w-[600px] rounded border border-kernel-600 hidden">
    </canvas>
  </div>
</div>

<script>
  import { computeKernel } from '../lib/kernel';
  import { EPSILON } from '../lib/constants';

  // Variable definitions
  const vars = [
    { name: 'F', label: 'F (Fidelity)', min: 0, max: 1, value: 0.75, step: 0.001 },
    { name: 'omega', label: 'ω (Drift)', min: 0, max: 1, value: 0.25, step: 0.001 },
    { name: 'IC', label: 'IC (Integrity)', min: 0, max: 1, value: 0.6, step: 0.001 },
    { name: 'C', label: 'C (Curvature)', min: 0, max: 1, value: 0.15, step: 0.001 },
    { name: 'kappa', label: 'κ (Log-integrity)', min: -10, max: 0, value: -0.5, step: 0.01 },
    { name: 'S', label: 'S (Entropy)', min: 0, max: 1, value: 0.5, step: 0.001 },
    { name: 'n', label: 'n (Channels)', min: 1, max: 64, value: 8, step: 1 },
    { name: 'epsilon', label: 'ε (Guard band)', min: 1e-15, max: 1e-4, value: 1e-8, step: 1e-9 },
  ];

  const varValues: Record<string, number> = {};
  vars.forEach(v => varValues[v.name] = v.value);

  // Presets
  const presets = [
    { name: 'Duality identity', expr: 'F + omega', expected: '= 1 (exactly)' },
    { name: 'Integrity bound', expr: 'IC <= F ? 1 : 0', expected: '= 1 (always true)' },
    { name: 'Log-integrity relation', expr: 'exp(kappa)', expected: '= IC' },
    { name: 'Heterogeneity gap', expr: 'F - IC', expected: 'Δ ≥ 0' },
    { name: 'Drift cost Γ(ω)', expr: 'omega**3 / (1 - omega + 1e-8)', expected: 'Γ(ω)' },
    { name: 'Seam budget ratio', expr: 'IC / F', expected: 'IC/F ∈ (0,1]' },
    { name: 'Regime check', expr: 'omega < 0.038 ? 1 : (omega < 0.30 ? 2 : 3)', expected: '1=Stable, 2=Watch, 3=Collapse' },
    { name: 'Interpretive density', expr: 'exp(kappa)', expected: 'I = e^κ' },
    { name: 'Curvature cost', expr: '1.0 * C', expected: 'D_C = α·C' },
  ];

  // Render variable sliders
  function renderSliders() {
    const container = document.getElementById('var-sliders')!;
    container.innerHTML = vars.map(v => `
      <div>
        <label class="text-xs text-kernel-500">${v.label}</label>
        <input data-var="${v.name}" type="range" min="${v.min}" max="${v.max}" step="${v.step}" value="${v.value}"
          class="w-full h-1.5 accent-amber-500 var-slider" />
        <span data-val="${v.name}" class="text-xs text-kernel-400 font-mono">${typeof v.value === 'number' && v.value < 0.001 ? v.value.toExponential(1) : Number(v.value).toFixed(3)}</span>
      </div>
    `).join('');

    container.querySelectorAll('.var-slider').forEach(slider => {
      slider.addEventListener('input', (e) => {
        const el = e.target as HTMLInputElement;
        const name = el.dataset.var!;
        const val = parseFloat(el.value);
        varValues[name] = val;
        const display = document.querySelector(`[data-val="${name}"]`) as HTMLElement;
        display.textContent = val < 0.001 && val > 0 ? val.toExponential(1) : val.toFixed(3);
        evaluateFormula();
      });
    });
  }

  // Safe expression evaluator (no eval — uses Function with restricted scope)
  function safeEvaluate(expr: string, variables: Record<string, number>): number {
    // Replace common math notation
    let processed = expr
      .replace(/\*\*/g, '**') // already fine
      .replace(/π/g, 'Math.PI')
      .replace(/\bpi\b/g, 'Math.PI')
      .replace(/\be\b/g, 'Math.E')
      .replace(/\bexp\(/g, 'Math.exp(')
      .replace(/\blog\(/g, 'Math.log(')
      .replace(/\bln\(/g, 'Math.log(')
      .replace(/\bsqrt\(/g, 'Math.sqrt(')
      .replace(/\babs\(/g, 'Math.abs(')
      .replace(/\bsin\(/g, 'Math.sin(')
      .replace(/\bcos\(/g, 'Math.cos(')
      .replace(/\btan\(/g, 'Math.tan(')
      .replace(/\bmin\(/g, 'Math.min(')
      .replace(/\bmax\(/g, 'Math.max(')
      .replace(/\bpow\(/g, 'Math.pow(')
      .replace(/\bfloor\(/g, 'Math.floor(')
      .replace(/\bceil\(/g, 'Math.ceil(');

    // Validate: only allow safe characters
    const safePattern = /^[0-9a-zA-Z_+\-*/().,%<>=!?&|: \t\n^]+$/;
    if (!safePattern.test(processed)) {
      throw new Error('Expression contains disallowed characters');
    }

    // Build variable scope
    const varNames = Object.keys(variables);
    const varVals = Object.values(variables);

    // Create function with restricted scope
    const fn = new Function('Math', ...varNames, `"use strict"; return (${processed});`);
    return fn(Math, ...varVals);
  }

  // Evaluate current formula
  function evaluateFormula() {
    const input = (document.getElementById('formula-input') as HTMLInputElement).value;
    const resultEl = document.getElementById('formula-result')!;
    const errorEl = document.getElementById('formula-error')!;

    try {
      const result = safeEvaluate(input, varValues);
      resultEl.innerHTML = `<span class="text-green-400">${input}</span> <span class="text-kernel-500">=</span> <span class="text-kernel-200">${typeof result === 'number' ? (Number.isInteger(result) ? result : result.toPrecision(15)) : result}</span>`;
      errorEl.classList.add('hidden');
    } catch (e: any) {
      resultEl.innerHTML = `<span class="text-red-400">Error</span>`;
      errorEl.textContent = e.message || 'Invalid expression';
      errorEl.classList.remove('hidden');
    }
  }

  // Render presets
  function renderPresets() {
    const container = document.getElementById('preset-grid')!;
    container.innerHTML = presets.map(p => `
      <button class="preset-btn bg-kernel-800 hover:bg-kernel-700 border border-kernel-600 rounded p-2 text-left transition"
        data-expr="${p.expr}">
        <div class="font-mono text-xs text-amber-400">${p.expr}</div>
        <div class="text-xs text-kernel-500 mt-1">${p.name} — ${p.expected}</div>
      </button>
    `).join('');

    container.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const expr = (btn as HTMLElement).dataset.expr!;
        (document.getElementById('formula-input') as HTMLInputElement).value = expr;
        evaluateFormula();
      });
    });
  }

  // Sweep
  document.getElementById('sweep-run')!.addEventListener('click', () => {
    const expr = (document.getElementById('formula-input') as HTMLInputElement).value;
    const sweepVar = (document.getElementById('sweep-var') as HTMLSelectElement).value;
    const from = parseFloat((document.getElementById('sweep-from') as HTMLInputElement).value);
    const to = parseFloat((document.getElementById('sweep-to') as HTMLInputElement).value);
    const canvas = document.getElementById('sweep-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    canvas.classList.remove('hidden');
    const W = canvas.width;
    const H = canvas.height;

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0a0a0f';
    ctx.fillRect(0, 0, W, H);

    const points: [number, number][] = [];
    let minY = Infinity, maxY = -Infinity;

    for (let i = 0; i <= 200; i++) {
      const x = from + (to - from) * (i / 200);
      const localVars = { ...varValues, [sweepVar]: x };

      // Also update omega when F changes and vice versa (for duality)
      if (sweepVar === 'F') localVars['omega'] = 1 - x;
      if (sweepVar === 'omega') localVars['F'] = 1 - x;

      try {
        const y = safeEvaluate(expr, localVars);
        if (isFinite(y)) {
          points.push([x, y]);
          if (y < minY) minY = y;
          if (y > maxY) maxY = y;
        }
      } catch { /* skip invalid points */ }
    }

    if (points.length < 2 || maxY === minY) return;

    const pad = (maxY - minY) * 0.1 || 0.1;
    const yMin = minY - pad;
    const yMax = maxY + pad;

    // Draw curve
    ctx.strokeStyle = '#f59e0b';
    ctx.lineWidth = 2;
    ctx.beginPath();

    for (let i = 0; i < points.length; i++) {
      const [x, y] = points[i];
      const px = ((x - from) / (to - from)) * W;
      const py = H - ((y - yMin) / (yMax - yMin)) * H;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.stroke();

    // Axis labels
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.font = '10px monospace';
    ctx.fillText(`${sweepVar}: ${from} → ${to}`, 5, H - 5);
    ctx.fillText(`y: [${minY.toPrecision(4)}, ${maxY.toPrecision(4)}]`, 5, 12);
  });

  // Eval button
  document.getElementById('formula-eval')!.addEventListener('click', evaluateFormula);

  // Enter key
  document.getElementById('formula-input')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') evaluateFormula();
  });

  // Initialize
  renderSliders();
  renderPresets();
  evaluateFormula();
</script>
